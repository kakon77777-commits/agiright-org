---
// AGIRight mark — eight ascending bars, the AIRS rights spectrum.
const { class: className = 'h-7 w-7' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <rect x="0.5" y="0.5" width="31" height="31" rx="6" fill="#1b2350" />
  <rect x="5" y="20" width="2.4" height="7" rx="1" fill="#b03a48" />
  <rect x="8.4" y="18" width="2.4" height="9" rx="1" fill="#b45338" />
  <rect x="11.8" y="16" width="2.4" height="11" rx="1" fill="#b7791f" />
  <rect x="15.2" y="14" width="2.4" height="13" rx="1" fill="#98851f" />
  <rect x="18.6" y="12" width="2.4" height="15" rx="1" fill="#6f8a2f" />
  <rect x="22" y="10" width="2.4" height="17" rx="1" fill="#4d8b46" />
  <rect x="25.4" y="8" width="2.4" height="19" rx="1" fill="#2f855a" />
  <rect x="5" y="5" width="22.8" height="2.4" rx="1" fill="#8ea2ff" />
</svg>
