---
import BaseLayout from '../layouts/BaseLayout.astro';
import { UI, SITE, langPrefix, type Lang, pick } from '../data/site';
import { getPaper, PAPERS } from '../data/papers';
import { PROTOCOLS } from '../data/protocols';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lang: Lang;
  entry: CollectionEntry<'whitepapers'>;
}
const { lang, entry } = Astro.props;
const t = UI[lang];
const prefix = langPrefix(lang);
const meta = getPaper(entry.id);
const { Content } = await render(entry);
const relatedProtocols = PROTOCOLS.filter((p) => meta.protocols.includes(p.id));
const langLabel =
  meta.lang === 'en' ? 'English' : meta.lang === 'zh-Hant' ? '繁體中文' : 'EN / 繁中';

// language variants: children of this paper, or the primary it belongs to
const otherVersions = [
  ...PAPERS.filter((x) => x.variantOf === meta.slug),
  ...(meta.variantOf ? [getPaper(meta.variantOf)] : []),
];
---

<BaseLayout lang={lang} title={pick(meta.title, lang)} description={pick(meta.oneLiner, lang)}>
  <section class="border-b border-line bg-surface">
    <div class="container-site py-12 md:py-16">
      <nav class="spec-label" aria-label="Breadcrumb" data-hero-line>
        <a href={prefix + '/docs'} class="hover:text-navy transition-colors duration-200">
          {pick({ en: 'Whitepapers', zh: '白皮書' }, lang)}
        </a>
        <span class="mx-2 text-line-strong">/</span>
        <span class="text-navy">{entry.id}</span>
      </nav>
      <h1 class="display-serif mt-6 max-w-4xl text-3xl md:text-[2.6rem]" data-hero-line>
        {pick(meta.title, lang)}
      </h1>
      <div class="mt-6 flex flex-wrap items-center gap-2" data-hero-line>
        <span class="badge badge-draft">{meta.version}</span>
        <span class="badge">{meta.date}</span>
        <span class="badge">{langLabel}</span>
        {meta.protocols.map((pid) => <span class="badge">{pid.toUpperCase()}</span>)}
      </div>
    </div>
  </section>

  <div class="container-site grid grid-cols-1 gap-14 py-12 md:py-16 lg:grid-cols-12">
    <article class="lg:col-span-8">
      <div class="rounded-md border-l-2 border-accent bg-accent-soft/40 px-5 py-4" data-reveal>
        <p class="spec-label !text-accent">{t.abstract}</p>
        <p class="mt-2.5 text-[0.95rem] leading-relaxed text-ink-soft">{pick(meta.abstract, lang)}</p>
      </div>
      <div class="prose-doc mt-12">
        <Content />
      </div>
    </article>

    <aside class="lg:col-span-4">
      <div class="lg:sticky lg:top-24 space-y-8">
        <div class="card p-6" data-reveal>
          <p class="spec-label">Metadata</p>
          <dl class="mt-4 space-y-3 text-[0.85rem]">
            <div class="flex justify-between gap-4">
              <dt class="text-muted">{t.author}</dt>
              <dd class="text-navy">{SITE.author} / {SITE.org}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-muted">{t.version}</dt>
              <dd class="font-mono text-navy">{meta.version}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-muted">{t.updated}</dt>
              <dd class="font-mono text-navy">{meta.date}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-muted">{t.language}</dt>
              <dd class="text-navy">{langLabel}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-muted">License</dt>
              <dd class="text-navy">CC BY 4.0</dd>
            </div>
          </dl>
        </div>

        {
          otherVersions.length > 0 && (
            <div class="card p-6" data-reveal>
              <p class="spec-label">{pick({ en: 'Other versions', zh: '其他版本' }, lang)}</p>
              <ul class="mt-3 space-y-2">
                {otherVersions.map((v) => (
                  <li>
                    <a
                      href={`${prefix}/docs/whitepapers/${v.slug}`}
                      class="link-quiet text-[0.9rem] font-medium"
                    >
                      {v.lang === 'zh-Hant'
                        ? pick({ en: 'Chinese original →', zh: '中文原稿 →' }, lang)
                        : pick({ en: 'English edition →', zh: '英文正式版 →' }, lang)}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <div class="card p-6" data-reveal>
          <p class="spec-label">{t.citeAs}</p>
          <p class="mt-3 font-mono text-[0.75rem] leading-relaxed text-ink-soft break-words">
            {SITE.author} / {SITE.org}, “{meta.title.en}”, {meta.version}, AGIRight.org,
            https://agiright.org/docs/whitepapers/{entry.id}
          </p>
        </div>

        {
          meta.keyConcepts.length > 0 && (
            <div data-reveal>
              <p class="spec-label mb-3">{t.keyConcepts}</p>
              <div class="flex flex-wrap gap-1.5">
                {meta.keyConcepts.map((c) => (
                  <span class="badge">{c}</span>
                ))}
              </div>
            </div>
          )
        }

        {
          relatedProtocols.length > 0 && (
            <div data-reveal>
              <p class="spec-label mb-4">{t.relatedProtocols}</p>
              <ul class="space-y-3">
                {relatedProtocols.map((p) => (
                  <li>
                    <a
                      href={`${prefix}/protocols/${p.id}`}
                      class="group block rounded-md border border-line bg-surface p-4 no-underline cursor-pointer hover:border-line-strong transition-colors duration-200"
                    >
                      <span class="font-mono text-[0.95rem] font-medium text-navy group-hover:text-primary transition-colors duration-200">
                        {p.abbr}
                      </span>
                      <span class="mt-1 block text-[0.8rem] leading-snug text-muted">{pick(p.expansion, lang)}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>
    </aside>
  </div>
</BaseLayout>
