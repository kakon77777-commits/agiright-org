---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from './PageHeader.astro';
import { pick, pickList, type Lang } from '../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const title = pick({ en: 'Changelog', zh: '更新紀錄' }, lang);
const intro =
  pick({ en: 'Version history of this site and its protocol drafts. Breaking spec changes are recorded here.', zh: '本站與各協議草案的版本紀錄。規格的重大變更都會記在這裡。' }, lang);

const ENTRIES = [
  {
    version: 'v0.5.1',
    date: '2026-07-12',
    tag: { en: 'Languages', zh: '多語言' },
    items: {
      en: [
        'Five more interface languages: French, German, Spanish, Portuguese, and Russian — same single-URL negotiation, same graceful English fallback for anything not yet translated.',
        'IP-country mapping extended (FR/BE→fr, DE/AT/CH→de, ES/MX/AR/CO/CL/PE→es, PT/BR→pt, RU/BY/KZ→ru); Accept-Language parsing extended to match.',
        'Ten languages live in total: English, Traditional Chinese, Simplified Chinese, Japanese, Korean, French, German, Spanish, Portuguese, Russian.',
      ],
      zh: [
        '新增五種介面語言:法文、德文、西班牙文、葡萄牙文、俄文——同樣的單一網址協商,同樣的缺譯自動回退英文。',
        'IP 國別對應擴充(FR/BE→fr、DE/AT/CH→de、ES/MX/AR/CO/CL/PE→es、PT/BR→pt、RU/BY/KZ→ru);Accept-Language 判斷同步擴充。',
        '目前共十種語言上線:英文、繁體中文、簡體中文、日文、韓文、法文、德文、西班牙文、葡萄牙文、俄文。',
      ],
    },
  },
  {
    version: 'v0.5.0',
    date: '2026-07-11',
    tag: { en: 'Languages', zh: '多語言' },
    items: {
      en: [
        'Three new interface languages: Simplified Chinese, Japanese, and Korean — negotiated at the same single URL (cookie > IP country > Accept-Language), selectable from the header language menu.',
        'N-language architecture: every string resolves through a fallback layer, so anything not yet translated renders in English instead of breaking; adding a language is now one translation file plus two lines of worker config.',
        'Whitepapers remain English-first by design; machine-readable files stay language-neutral.',
      ],
      zh: [
        '新增三種介面語言:簡體中文、日文、韓文——同一網址協商(cookie > IP 國別 > Accept-Language),也可從頁首語言選單切換。',
        'N 語架構:所有字串經過回退層解析,尚未翻譯的內容以英文呈現而非破版;新增語言只需一份翻譯檔加兩行 worker 設定。',
        '白皮書依設計維持英文為主;機器可讀層維持語言中立。',
      ],
    },
  },
  {
    version: 'v0.4.1',
    date: '2026-07-11',
    tag: { en: 'Studio', zh: '影音' },
    items: {
      en: [
        'Studio section: four videos and two long-form audio discussions accompanying the protocols and papers (AI-assisted production; the written papers remain authoritative).',
        'Media served from Cloudflare R2 through the site worker at /media/*, with HTTP Range support for seeking.',
      ],
      zh: [
        '影音區上線:四支影片與兩集長篇音頻,對應各協議與論文(AI 輔助製作;正式論述以文字版為準)。',
        '媒體檔由 Cloudflare R2 經站點 worker 於 /media/* 提供,支援 HTTP Range 拖放進度。',
      ],
    },
  },
  {
    version: 'v0.4.0',
    date: '2026-07-10',
    tag: { en: 'Adoption tools', zh: '採用工具' },
    items: {
      en: [
        'Policy tester upgraded into a site audit: adoption score, actionable recommendations, and a one-click starter kit — aicr.json, aicl.json, llms.txt, and robots.txt prefilled for the inspected domain.',
        'AI crawler simulator: four personas (search indexer, RAG assistant, model-training pipeline, commercial redistributor) evaluated against a site’s declarations; undeclared rights surface as uncertainty, illustrating the Protocolized Openness thesis.',
        'Deployable policy starter template at /downloads/agiright-policy-starter.zip — a minimal static site with the full machine-readable layer, ready for Cloudflare Pages or any static host.',
      ],
      zh: [
        '政策測試器升級為網站稽核:採用度評分、可執行的建議,以及一鍵 starter kit——依受測網域預填的 aicr.json、aicl.json、llms.txt、robots.txt。',
        'AI 爬蟲模擬器:四種角色(搜尋索引器、RAG 助理、模型訓練管線、商業再分發者)對照網站宣告逐一判定;未宣告的權利呈現為不確定性——正是《協議化開放》的論點。',
        '可部署的政策 starter 模板 /downloads/agiright-policy-starter.zip——含完整機器可讀層的最小靜態站,可直接上 Cloudflare Pages 或任何靜態主機。',
      ],
    },
  },
  {
    version: 'v0.3.0',
    date: '2026-07-10',
    tag: { en: 'Protocol tools', zh: '協議工具' },
    items: {
      en: [
        'Protocol registry at /ai/registry.json — every draft with version history, status, schema, and live instance.',
        'Live demo API on the edge: GET /api/mock/402 returns a real AICL-style HTTP 402 with machine-actionable licensing info; GET /api/crawler-check inspects any site’s machine-readable policy surface. CORS-open; documented in OpenAPI 3.1 at /ai/openapi.json. No payments are processed.',
        'Playground: three new tools — signed license token demo (HMAC-SHA256 in-browser: sign, verify, tamper detection, expiry), HTTP 402 response builder wired to the live endpoint, and a crawler policy tester that validates fetched files against the draft schemas.',
        'AICL quote/verify/revoke endpoints included in the OpenAPI document as specification-only illustrations (marked x-specification-only, not implemented).',
      ],
      zh: [
        '協議 registry 上線 /ai/registry.json——每個草案的版本歷史、狀態、schema 與 live 實例。',
        '邊緣 live demo API:GET /api/mock/402 回傳真實的 AICL 式 HTTP 402(機器可行動的授權資訊);GET /api/crawler-check 檢測任一網站的機器可讀政策層。開放 CORS;以 OpenAPI 3.1 記載於 /ai/openapi.json。不處理任何真實付款。',
        '實驗工具新增三項——簽章授權憑證 demo(瀏覽器內 HMAC-SHA256:簽發、驗證、竄改偵測、時效)、HTTP 402 回應產生器(可直接呼叫 live 端點)、爬蟲政策測試器(以草案 schema 驗證抓到的檔案)。',
        'AICL 的 quote/verify/revoke 端點以「僅規格說明」形式納入 OpenAPI(標示 x-specification-only,未實作)。',
      ],
    },
  },
  {
    version: 'v0.2.2',
    date: '2026-07-10',
    tag: { en: 'i18n', zh: '多語言' },
    items: {
      en: [
        'Single-URL multilingual architecture: every page now has one public URL; the language is negotiated at the edge (manual choice via lang cookie > IP country > Accept-Language > English).',
        'The header language button now switches in place and remembers your choice — no more /zh URLs; legacy /zh links 301-redirect and preserve the preference.',
        'Machine-readable layer stays language-neutral; AI systems and crawlers receive English by default. Negotiation is documented in /ai/manifest.json and /llms.txt.',
        'Groundwork for additional languages: each new language is a translated dictionary plus a build tree — no architecture change.',
      ],
      zh: [
        '單一網址多語言架構:每個頁面只有一個公開網址,語言在邊緣協商(手動選擇 lang cookie > IP 國別 > Accept-Language > 英文)。',
        '頁首語言鈕改為原地切換並記住選擇——不再有 /zh 網址;舊 /zh 連結 301 轉向並保留偏好。',
        '機器可讀層維持語言中立;AI 系統與爬蟲預設取得英文。協商方式記載於 /ai/manifest.json 與 /llms.txt。',
        '為更多語言鋪路:新增語言只需翻譯字典 + 建置樹,不動架構。',
      ],
    },
  },
  {
    version: 'v0.2.1',
    date: '2026-07-04',
    tag: { en: 'Content', zh: '內容' },
    items: {
      en: [
        '“AICL: AI Ingestion & Capability Layer” now published in English as the canonical edition; the Chinese original manuscript remains available and both versions cross-link.',
        '“Protocolized Openness” confirmed as an English-language paper (with Chinese parallel passages) — no separate translation planned.',
      ],
      zh: [
        '《AICL:AI 攝取與能力層》英文版上線並成為正式版本;中文原稿保留於站上,兩版互相連結。',
        '《協議化開放》確認為英文論文(含中文對照段落)——不另行翻譯。',
      ],
    },
  },
  {
    version: 'v0.2',
    date: '2026-07-04',
    tag: { en: 'Tools', zh: '工具' },
    items: {
      en: [
        'Playground: working AICR generator, AICL generator, and schema validator (in-browser, ajv, draft 2020-12).',
        'Policy examples library at /docs/examples — seven copy-paste-ready policies including a pay-per-crawl style HTTP 402 response.',
        'This changelog. GitHub repository linked site-wide.',
        'Pending for a later 0.2.x: English versions of the remaining Chinese-language whitepapers.',
      ],
      zh: [
        '實驗工具:可用的 AICR 產生器、AICL 產生器與 schema 驗證器(瀏覽器內執行,ajv,draft 2020-12)。',
        '政策範例庫 /docs/examples——七個可直接取用的政策,含 pay-per-crawl 式 HTTP 402 回應。',
        '本更新紀錄。全站加上 GitHub repository 連結。',
        '留待 0.2.x:其餘中文白皮書的英文版。',
      ],
    },
  },
  {
    version: 'v0.1',
    date: '2026-07-04',
    tag: { en: 'Initial release', zh: '首次發布' },
    items: {
      en: [
        'Site launched at agiright.org (asiright.org 301-redirects to the canonical domain).',
        'Four protocol drafts published: AICR, AICL, AIRS, AILP — each with definition, scope, JSON example, limitations, and JSON Schema.',
        'Six research whitepapers published under CC BY 4.0.',
        'Machine-readable governance layer deployed: llms.txt, /ai/ manifests, /.well-known/ policies, /schemas/.',
        'Bilingual: English root + Traditional Chinese under /zh.',
      ],
      zh: [
        '網站於 agiright.org 上線(asiright.org 以 301 指向主域)。',
        '發布四個協議草案:AICR、AICL、AIRS、AILP——各含定義、範圍、JSON 範例、限制與 JSON Schema。',
        '以 CC BY 4.0 發布六篇研究白皮書。',
        '部署機器可讀治理層:llms.txt、/ai/ 清單、/.well-known/ 政策、/schemas/。',
        '雙語:英文主站 + /zh 繁體中文。',
      ],
    },
  },
];
---

<BaseLayout lang={lang} title={title} description={intro}>
  <PageHeader kicker={pick({ en: 'Docs', zh: '文件' }, lang)} title={title} intro={intro} />
  <div class="container-site max-w-3xl py-14 md:py-20">
    <div class="space-y-14">
      {
        ENTRIES.map((entry) => (
          <section class="relative border-l-2 border-line pl-7" data-reveal>
            <span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full border-2 border-paper bg-primary" aria-hidden="true" />
            <div class="flex flex-wrap items-center gap-3">
              <h2 class="font-mono text-xl font-medium text-navy">{entry.version}</h2>
              <span class="badge">{entry.date}</span>
              <span class="badge badge-live">{pick(entry.tag, lang)}</span>
            </div>
            <ul class="mt-5 space-y-3">
              {pickList(entry.items, lang).map((item) => (
                <li class="flex gap-3 text-[0.95rem] leading-relaxed text-ink-soft">
                  <span class="mt-2.5 h-1 w-1 shrink-0 rounded-full bg-line-strong" aria-hidden="true" />
                  {item}
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
