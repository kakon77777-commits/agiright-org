---

<BaseLayout lang={lang} title={title} description={intro}>
  <PageHeader kicker={pick({ en: 'Docs', zh: '文件' }, lang)} title={title} intro={intro} />
  <div class="container-site max-w-3xl py-14 md:py-20">
    <div class="space-y-14">
      {
        ENTRIES.map((entry) => (
          <section class="relative border-l-2 border-line pl-7" data-reveal>
            <span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full border-2 border-paper bg-primary" aria-hidden="true" />
            <div class="flex flex-wrap items-center gap-3">
              <h2 class="font-mono text-xl font-medium text-navy">{entry.version}</h2>
              <span class="badge">{entry.date}</span>
              <span class="badge badge-live">{pick(entry.tag, lang)}</span>
            </div>
            <ul class="mt-5 space-y-3">
              {pickList(entry.items, lang).map((item) => (
                <li class="flex gap-3 text-[0.95rem] leading-relaxed text-ink-soft">
                  <span class="mt-2.5 h-1 w-1 shrink-0 rounded-full bg-line-strong" aria-hidden="true" />
                  {item}
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
