---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonBlock from './JsonBlock.astro';
import SpectrumViz from './SpectrumViz.astro';
import { UI, langPrefix, type Lang, pick, pickList } from '../data/site';
import { getProtocol, PROTOCOLS } from '../data/protocols';
import { PAPERS } from '../data/papers';

interface Props {
  lang: Lang;
  id: string;
}
const { lang, id } = Astro.props;
const t = UI[lang];
const prefix = langPrefix(lang);
const p = getProtocol(id);
const related = PAPERS.filter((paper) => p.relatedPapers.includes(paper.slug));
const others = PROTOCOLS.filter((x) => x.id !== p.id);
---

<BaseLayout lang={lang} title={pick(p.name, lang)} description={pick(p.tagline, lang)}>
  <!-- header -->
  <section class="border-b border-line bg-surface">
    <div class="container-site py-14 md:py-18">
      <nav class="spec-label" aria-label="Breadcrumb" data-hero-line>
        <a href={prefix + '/protocols'} class="hover:text-navy transition-colors duration-200">{pick({ en: 'Protocols', zh: '協議' }, lang)}</a>
        <span class="mx-2 text-line-strong">/</span>
        <span class="text-navy">{p.abbr}</span>
      </nav>
      <div class="mt-6 flex flex-wrap items-start justify-between gap-6">
        <div class="max-w-3xl">
          <h1 class="display-serif text-4xl md:text-5xl" data-hero-line>{pick(p.name, lang)}</h1>
          <p class="mt-3 spec-label" data-hero-line>{pick(p.expansion, lang)}</p>
          <p class="mt-6 text-lg leading-relaxed text-ink-soft" data-hero-line>{pick(p.tagline, lang)}</p>
        </div>
        <div class="flex flex-col items-end gap-2" data-hero-line>
          <span class="badge badge-draft">{p.status}</span>
          <a href={p.schemaUrl} class="font-mono text-[0.78rem] text-spec hover:text-navy transition-colors duration-200" download>
            {t.schema} ↓
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="container-site grid grid-cols-1 gap-14 py-14 lg:grid-cols-12 md:py-20">
    <div class="lg:col-span-8 space-y-16">
      <!-- definition -->
      <section data-reveal>
        <h2 class="spec-label !text-accent">01 · {t.definition}</h2>
        <p class="mt-4 max-w-2xl text-[1.05rem] leading-[1.85] text-ink-soft">{pick(p.definition, lang)}</p>
      </section>

      <!-- purpose -->
      <section data-reveal>
        <h2 class="spec-label !text-accent">02 · {t.purpose}</h2>
        <ul class="mt-5 max-w-2xl space-y-3.5">
          {
            pickList(p.purpose, lang).map((item) => (
              <li class="flex gap-3 text-[0.98rem] leading-relaxed text-ink-soft">
                <svg class="mt-1.5 h-3.5 w-3.5 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
      </section>

      <!-- scope -->
      <section data-reveal>
        <h2 class="spec-label !text-accent">03 · {t.scope}</h2>
        <div class="mt-5 overflow-hidden rounded-lg border border-line">
          {
            pickList(p.scope, lang).map((item, i) => {
              const [head, ...rest] = item.split('—');
              return (
                <div class:list={['flex gap-4 bg-surface px-5 py-3.5', i > 0 && 'border-t border-line']}>
                  <span class="font-mono text-[0.72rem] font-medium text-muted pt-0.5 w-6 shrink-0">
                    {String(i).padStart(2, '0')}
                  </span>
                  <p class="text-[0.92rem] leading-relaxed text-ink-soft">
                    <span class="font-mono text-[0.85rem] font-medium text-navy">{head.trim()}</span>
                    {rest.length > 0 && <span class="text-muted"> — {rest.join('—').trim()}</span>}
                  </p>
                </div>
              );
            })
          }
        </div>
        {p.id === 'airs' && (
          <div class="mt-8">
            <SpectrumViz lang={lang} />
          </div>
        )}
      </section>

      <!-- example -->
      <section data-reveal>
        <h2 class="spec-label !text-accent">04 · {t.example}</h2>
        <p class="mt-4 text-[0.95rem] text-ink-soft">{pick(p.exampleTitle, lang)}</p>
        <JsonBlock code={p.jsonExample} file={p.exampleFile} class="mt-4" />
      </section>

      <!-- limitations -->
      <section data-reveal>
        <h2 class="spec-label !text-warn">05 · {t.limitations}</h2>
        <ul class="mt-5 max-w-2xl space-y-3">
          {
            pickList(p.limitations, lang).map((item) => (
              <li class="flex gap-3 text-[0.92rem] leading-relaxed text-muted">
                <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-warn" aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>
      </section>

      {
        p.namingNote && (
          <section class="rounded-md border-l-2 border-spec bg-spec-soft/60 px-5 py-4" data-reveal>
            <h2 class="spec-label !text-spec">{t.namingNote}</h2>
            <p class="mt-3 max-w-2xl text-[0.9rem] leading-relaxed text-ink-soft">{pick(p.namingNote, lang)}</p>
          </section>
        )
      }
    </div>

    <!-- sidebar -->
    <aside class="lg:col-span-4">
      <div class="lg:sticky lg:top-24 space-y-8">
        <div class="card p-6" data-reveal>
          <p class="spec-label">{t.status}</p>
          <dl class="mt-4 space-y-3 text-[0.88rem]">
            <div class="flex justify-between gap-4">
              <dt class="text-muted">{t.version}</dt>
              <dd class="font-mono text-navy">{p.status}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-muted">{t.schema}</dt>
              <dd><a href={p.schemaUrl} class="font-mono text-[0.8rem] text-spec hover:text-navy transition-colors duration-200">{p.schemaUrl}</a></dd>
            </div>
            {
              p.wellKnownUrl && (
                <div class="flex justify-between gap-4">
                  <dt class="text-muted">Live</dt>
                  <dd>
                    <a href={p.wellKnownUrl} class="font-mono text-[0.8rem] text-spec hover:text-navy transition-colors duration-200">
                      {p.wellKnownUrl}
                    </a>
                  </dd>
                </div>
              )
            }
          </dl>
        </div>

        {
          related.length > 0 && (
            <div data-reveal>
              <p class="spec-label mb-4">{pick({ en: 'Related whitepapers', zh: '相關白皮書' }, lang)}</p>
              <ul class="space-y-3">
                {related.map((paper) => (
                  <li>
                    <a
                      href={`${prefix}/docs/whitepapers/${paper.slug}`}
                      class="group block rounded-md border border-line bg-surface p-4 no-underline cursor-pointer hover:border-line-strong transition-colors duration-200"
                    >
                      <span class="font-serif text-[0.95rem] font-semibold leading-snug text-navy group-hover:text-primary transition-colors duration-200">
                        {pick(paper.title, lang)}
                      </span>
                      <span class="mt-1.5 block spec-label">{paper.version}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <div data-reveal>
          <p class="spec-label mb-4">{t.allProtocols}</p>
          <ul class="space-y-2">
            {
              others.map((o) => (
                <li>
                  <a
                    href={`${prefix}/protocols/${o.id}`}
                    class="group flex items-baseline gap-3 py-1 no-underline cursor-pointer"
                  >
                    <span class="font-mono text-[0.85rem] font-medium text-navy group-hover:text-primary transition-colors duration-200">{o.abbr}</span>
                    <span class="text-[0.8rem] text-muted">{pick(o.expansion, lang)}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
