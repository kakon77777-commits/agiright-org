---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from './PageHeader.astro';
import type { Lang } from '../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const title = lang === 'zh' ? '實驗工具' : 'Playground';
const intro =
  lang === 'zh'
    ? '在瀏覽器內產生與驗證機器可讀政策檔。所有工具皆在本地執行,不上傳任何資料。'
    : 'Generate and validate machine-readable policy files, entirely in your browser. Nothing is uploaded.';

const T = {
  tabAicr: lang === 'zh' ? 'AICR 產生器' : 'AICR generator',
  tabAicl: lang === 'zh' ? 'AICL 產生器' : 'AICL generator',
  tabValidate: lang === 'zh' ? '驗證器' : 'Validator',
  publisher: lang === 'zh' ? '發布者(網站名稱)' : 'Publisher (site name)',
  contact: lang === 'zh' ? '授權聯絡 email' : 'Licensing contact email',
  rights: lang === 'zh' ? '權利設定' : 'Rights',
  allowed: lang === 'zh' ? '允許' : 'Allowed',
  licenseRequired: lang === 'zh' ? '需授權' : 'License required',
  denied: lang === 'zh' ? '拒絕' : 'Denied',
  attribution: lang === 'zh' ? '需署名' : 'Attribution',
  maxWords: lang === 'zh' ? '引用字數上限' : 'Max excerpt words',
  retention: lang === 'zh' ? '保存天數' : 'Retention days',
  output: lang === 'zh' ? '輸出' : 'Output',
  copy: lang === 'zh' ? '複製' : 'Copy',
  copied: lang === 'zh' ? '已複製 ✓' : 'Copied ✓',
  download: lang === 'zh' ? '下載' : 'Download',
  deployHint:
    lang === 'zh'
      ? '將產生的檔案放到你網站的 /.well-known/ 目錄,並在 llms.txt 中宣告。'
      : 'Place the generated file under /.well-known/ on your site and declare it in llms.txt.',
  presets: lang === 'zh' ? '授權級距' : 'License tiers',
  presetFree: lang === 'zh' ? '免費讀取+摘要(需署名)' : 'Free read + summarize (attribution)',
  presetRag: lang === 'zh' ? '研究用 RAG(免費、30 天保存)' : 'Research RAG (free, 30-day retention)',
  presetCommercial: lang === 'zh' ? '訓練/商用(聯絡授權)' : 'Training / commercial (contact)',
  customTier: lang === 'zh' ? '自訂級距' : 'Custom tier',
  customEnable: lang === 'zh' ? '加入自訂級距' : 'Add a custom tier',
  tierId: lang === 'zh' ? '級距 ID' : 'Tier id',
  tierRights: lang === 'zh' ? '包含權利' : 'Rights included',
  price: lang === 'zh' ? '價格' : 'Price',
  currency: lang === 'zh' ? '幣別' : 'Currency',
  conditions: lang === 'zh' ? '條件(逗號分隔)' : 'Conditions (comma-separated)',
  requiresContact: lang === 'zh' ? '需聯絡洽談' : 'Requires contact',
  schema: 'Schema',
  autoDetect: lang === 'zh' ? '自動偵測' : 'Auto-detect',
  pasteJson: lang === 'zh' ? '貼上要驗證的 JSON' : 'Paste JSON to validate',
  validate: lang === 'zh' ? '驗證' : 'Validate',
  valid: lang === 'zh' ? '✓ 有效 — 符合' : '✓ Valid against',
  invalid: lang === 'zh' ? '✗ 不符合 schema' : '✗ Does not match schema',
  syntaxError: lang === 'zh' ? 'JSON 語法錯誤' : 'JSON syntax error',
  loadExample: lang === 'zh' ? '載入本站範例' : 'Load this site’s file',
  localNote:
    lang === 'zh'
      ? '// 產生器與驗證器完全在本地執行;授權憑證 demo 亦同。政策測試器會經由本站 API 讀取你指定網站的公開政策檔。'
      : '// Generators, validator, and the token demo run entirely locally. The policy tester fetches a site’s public policy files via this site’s API.',
  // --- token demo ---
  tabToken: lang === 'zh' ? '授權憑證 demo' : 'License token',
  tokenLicense: lang === 'zh' ? '授權級距' : 'License',
  tokenAgent: lang === 'zh' ? 'Agent 識別' : 'Agent identity',
  tokenScope: lang === 'zh' ? '適用範圍(路徑)' : 'Scope (path)',
  tokenTtl: lang === 'zh' ? '有效分鐘數' : 'TTL (minutes)',
  tokenSecret: lang === 'zh' ? '共享密鑰(demo)' : 'Shared secret (demo)',
  tokenSign: lang === 'zh' ? '簽發憑證' : 'Sign token',
  tokenVerify: lang === 'zh' ? '驗證' : 'Verify',
  tokenTamper: lang === 'zh' ? '竄改一個字元' : 'Tamper one character',
  tokenPaste: lang === 'zh' ? '貼上要驗證的憑證' : 'Token to verify',
  tokenValid: lang === 'zh' ? '✓ 簽章有效' : '✓ Signature valid',
  tokenInvalid: lang === 'zh' ? '✗ 簽章無效(內容已被竄改或密鑰不符)' : '✗ Invalid signature (tampered or wrong secret)',
  tokenExpired: lang === 'zh' ? '⚠ 簽章有效,但憑證已過期' : '⚠ Signature valid, but the token has expired',
  tokenNote:
    lang === 'zh'
      ? '教學用 demo:以 HMAC-SHA256 與共享密鑰示範「請求綁定、有時效、可驗證」的授權憑證。正式環境應由發布者以非對稱金鑰簽章,驗證方使用 /.well-known/ 公開的公鑰。'
      : 'Educational demo: HMAC-SHA256 with a shared secret, showing request-bound, expiring, verifiable license tokens. Production tokens should be signed asymmetrically, with the publisher’s public key discoverable under /.well-known/.',
  // --- 402 builder ---
  tabHttp402: 'HTTP 402',
  h402Resource: lang === 'zh' ? '受保護資源路徑' : 'Protected resource path',
  h402Unit: lang === 'zh' ? '計價單位' : 'Pricing unit',
  h402Build: lang === 'zh' ? '產生回應' : 'Build response',
  h402Live: lang === 'zh' ? '呼叫本站的 live mock 端點' : 'Call this site’s live mock endpoint',
  h402LiveNote:
    lang === 'zh'
      ? '這是真的端點——任何 Agent 都可以打:'
      : 'This is a real endpoint — any agent can call it:',
  h402Note:
    lang === 'zh'
      ? 'AICL 的核心主張:對未授權的 AI 請求,不要回死路(403/空白),而是回機器可行動的 402——附授權目錄、價格與洽詢方式。本站不處理真實付款。'
      : 'The AICL thesis: answer unlicensed AI requests not with a dead end (403/blank) but with a machine-actionable 402 — license catalog, prices, and contact. This site processes no real payments.',
  // --- crawler tester ---
  tabTester: lang === 'zh' ? '政策測試器' : 'Policy tester',
  testerOrigin: lang === 'zh' ? '要檢測的網站(https)' : 'Site to inspect (https)',
  testerRun: lang === 'zh' ? '檢測' : 'Inspect',
  testerRunning: lang === 'zh' ? '檢測中…' : 'Inspecting…',
  testerFound: lang === 'zh' ? '存在' : 'found',
  testerMissing: lang === 'zh' ? '不存在' : 'missing',
  testerValid: lang === 'zh' ? '符合 schema' : 'schema-valid',
  testerInvalid: lang === 'zh' ? '不符合 schema' : 'schema-invalid',
  testerNote:
    lang === 'zh'
      ? '檢查任一網站的機器可讀政策層:robots.txt、llms.txt、AICR/AICL 政策檔與權利光譜宣告,並以本站草案 schema 驗證。'
      : 'Inspect any site’s machine-readable policy surface: robots.txt, llms.txt, AICR/AICL policies, and rights-spectrum declarations — validated against this site’s draft schemas.',
};

const RIGHTS: { key: string; label: string; attr?: boolean; words?: boolean; retention?: boolean; def: string }[] = [
  { key: 'read_access', label: lang === 'zh' ? '讀取' : 'Read access', def: 'allowed' },
  { key: 'summarization', label: lang === 'zh' ? '摘要' : 'Summarization', attr: true, def: 'allowed' },
  { key: 'quotation', label: lang === 'zh' ? '引用' : 'Quotation', attr: true, words: true, def: 'allowed' },
  { key: 'rag_use', label: 'RAG', attr: true, retention: true, def: 'allowed' },
  { key: 'transformation', label: lang === 'zh' ? '轉換' : 'Transformation', def: 'license_required' },
  { key: 'training', label: lang === 'zh' ? '訓練' : 'Training', def: 'license_required' },
  { key: 'commercial_use', label: lang === 'zh' ? '商業使用' : 'Commercial use', def: 'license_required' },
  { key: 'redistribution', label: lang === 'zh' ? '再分發' : 'Redistribution', def: 'denied' },
];

const AICL_RIGHT_OPTIONS = ['read', 'summarize', 'quote', 'rag', 'transform', 'training', 'fine_tuning', 'commercial_use'];
---

<BaseLayout lang={lang} title={title} description={intro}>
  <PageHeader kicker={lang === 'zh' ? '工具' : 'Tools'} title={title} intro={intro} badges={['v0.3', lang === 'zh' ? '瀏覽器內執行 + live API' : 'in-browser + live API']} />

  <div class="container-site py-12 md:py-16" data-playground data-lang={lang}>
    <!-- tabs -->
    <div role="tablist" aria-label="Playground tools" class="flex flex-wrap gap-2" data-reveal>
      <button class="tab-btn" role="tab" id="tab-aicr" aria-selected="true" aria-controls="panel-aicr" data-tab="aicr">{T.tabAicr}</button>
      <button class="tab-btn" role="tab" id="tab-aicl" aria-selected="false" aria-controls="panel-aicl" data-tab="aicl">{T.tabAicl}</button>
      <button class="tab-btn" role="tab" id="tab-validate" aria-selected="false" aria-controls="panel-validate" data-tab="validate">{T.tabValidate}</button>
      <button class="tab-btn" role="tab" id="tab-token" aria-selected="false" aria-controls="panel-token" data-tab="token">{T.tabToken}</button>
      <button class="tab-btn" role="tab" id="tab-h402" aria-selected="false" aria-controls="panel-h402" data-tab="h402">{T.tabHttp402}</button>
      <button class="tab-btn" role="tab" id="tab-tester" aria-selected="false" aria-controls="panel-tester" data-tab="tester">{T.tabTester}</button>
    </div>
    <p class="mt-3 font-mono text-[0.72rem] text-muted" data-reveal>{T.localNote}</p>

    <!-- ============ AICR GENERATOR ============ -->
    <section id="panel-aicr" role="tabpanel" aria-labelledby="tab-aicr" class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-2" data-panel="aicr">
      <div class="card p-6 md:p-7">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label class="field-label" for="aicr-publisher">{T.publisher}</label>
            <input class="field-input" id="aicr-publisher" type="text" value="example.org" data-aicr-publisher />
          </div>
          <div>
            <label class="field-label" for="aicr-contact">{T.contact}</label>
            <input class="field-input" id="aicr-contact" type="email" value="contact@example.org" data-aicr-contact />
          </div>
        </div>

        <p class="field-label mt-7">{T.rights}</p>
        <div class="overflow-hidden rounded-md border border-line">
          {
            RIGHTS.map((r, i) => (
              <div class:list={['bg-surface px-4 py-3.5', i > 0 && 'border-t border-line']} data-right={r.key}>
                <div class="flex flex-wrap items-center gap-3">
                  <span class="w-32 shrink-0 font-mono text-[0.78rem] font-medium text-navy">{r.key}</span>
                  <select class="field-select !w-auto flex-none text-[0.85rem]" aria-label={`${r.label} mode`} data-mode>
                    <option value="allowed" selected={r.def === 'allowed'}>{T.allowed}</option>
                    <option value="license_required" selected={r.def === 'license_required'}>{T.licenseRequired}</option>
                    <option value="denied" selected={r.def === 'denied'}>{T.denied}</option>
                  </select>
                  {r.attr && (
                    <label class="field-check">
                      <input type="checkbox" checked data-attr />
                      {T.attribution}
                    </label>
                  )}
                  {r.words && (
                    <label class="field-check gap-2">
                      <span class="text-[0.78rem] text-muted">{T.maxWords}</span>
                      <input class="field-input !w-20 !py-1 text-[0.85rem]" type="number" min="0" value="200" data-max-words />
                    </label>
                  )}
                  {r.retention && (
                    <label class="field-check gap-2">
                      <span class="text-[0.78rem] text-muted">{T.retention}</span>
                      <input class="field-input !w-20 !py-1 text-[0.85rem]" type="number" min="0" value="30" data-retention />
                    </label>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between gap-3">
          <p class="field-label !mb-0">{T.output} — aicr.json</p>
          <div class="flex gap-2">
            <button class="btn btn-outline !px-3 !py-2 !text-[0.8rem]" data-copy="aicr">{T.copy}</button>
            <button class="btn btn-primary !px-3 !py-2 !text-[0.8rem]" data-download="aicr" data-filename="aicr.json">{T.download}</button>
          </div>
        </div>
        <figure class="terminal mt-3">
          <pre class="max-h-[32rem] overflow-auto p-4"><code data-output="aicr"></code></pre>
        </figure>
        <p class="mt-3 text-[0.8rem] leading-relaxed text-muted">{T.deployHint}</p>
      </div>
    </section>

    <!-- ============ AICL GENERATOR ============ -->
    <section id="panel-aicl" role="tabpanel" aria-labelledby="tab-aicl" class="mt-8 hidden grid-cols-1 gap-8 lg:grid-cols-2" data-panel="aicl">
      <div class="card p-6 md:p-7">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label class="field-label" for="aicl-publisher">{T.publisher}</label>
            <input class="field-input" id="aicl-publisher" type="text" value="example.org" data-aicl-publisher />
          </div>
          <div>
            <label class="field-label" for="aicl-contact">{T.contact}</label>
            <input class="field-input" id="aicl-contact" type="email" value="contact@example.org" data-aicl-contact />
          </div>
        </div>

        <p class="field-label mt-7">{T.presets}</p>
        <div class="space-y-2.5">
          <label class="field-check"><input type="checkbox" checked data-preset="public_read_summary" /> {T.presetFree}</label><br />
          <label class="field-check"><input type="checkbox" checked data-preset="research_rag" /> {T.presetRag}</label><br />
          <label class="field-check"><input type="checkbox" checked data-preset="commercial_or_training_license" /> {T.presetCommercial}</label>
        </div>

        <p class="field-label mt-7">{T.customTier}</p>
        <label class="field-check"><input type="checkbox" data-custom-enable /> {T.customEnable}</label>
        <div class="mt-4 hidden space-y-4 rounded-md border border-line bg-paper px-4 py-4" data-custom-fields>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
            <div>
              <label class="field-label" for="aicl-tier-id">{T.tierId}</label>
              <input class="field-input" id="aicl-tier-id" type="text" value="premium_rag" data-tier-id />
            </div>
            <div>
              <label class="field-label" for="aicl-price">{T.price}</label>
              <input class="field-input" id="aicl-price" type="text" value="0.01" data-tier-price />
            </div>
            <div>
              <label class="field-label" for="aicl-currency">{T.currency}</label>
              <input class="field-input" id="aicl-currency" type="text" value="USD" data-tier-currency />
            </div>
          </div>
          <div>
            <p class="field-label">{T.tierRights}</p>
            <div class="flex flex-wrap gap-x-4 gap-y-2">
              {
                AICL_RIGHT_OPTIONS.map((r) => (
                  <label class="field-check">
                    <input type="checkbox" checked={r === 'read' || r === 'rag'} data-tier-right={r} />
                    <span class="font-mono text-[0.78rem]">{r}</span>
                  </label>
                ))
              }
            </div>
          </div>
          <div>
            <label class="field-label" for="aicl-conditions">{T.conditions}</label>
            <input class="field-input" id="aicl-conditions" type="text" value="attribution_required, retention_days_30" data-tier-conditions />
          </div>
          <label class="field-check"><input type="checkbox" data-tier-contact /> {T.requiresContact}</label>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between gap-3">
          <p class="field-label !mb-0">{T.output} — aicl.json</p>
          <div class="flex gap-2">
            <button class="btn btn-outline !px-3 !py-2 !text-[0.8rem]" data-copy="aicl">{T.copy}</button>
            <button class="btn btn-primary !px-3 !py-2 !text-[0.8rem]" data-download="aicl" data-filename="aicl.json">{T.download}</button>
          </div>
        </div>
        <figure class="terminal mt-3">
          <pre class="max-h-[32rem] overflow-auto p-4"><code data-output="aicl"></code></pre>
        </figure>
        <p class="mt-3 text-[0.8rem] leading-relaxed text-muted">{T.deployHint}</p>
      </div>
    </section>

    <!-- ============ VALIDATOR ============ -->
    <section id="panel-validate" role="tabpanel" aria-labelledby="tab-validate" class="mt-8 hidden grid-cols-1 gap-8 lg:grid-cols-2" data-panel="validate">
      <div class="card p-6 md:p-7">
        <div class="flex flex-wrap items-end gap-4">
          <div>
            <label class="field-label" for="val-schema">{T.schema}</label>
            <select class="field-select !w-auto" id="val-schema" data-val-schema>
              <option value="auto">{T.autoDetect}</option>
              <option value="aicr">aicr.schema.json</option>
              <option value="aicl">aicl.schema.json</option>
              <option value="airs">airs.schema.json</option>
              <option value="ailp">ailp.schema.json</option>
            </select>
          </div>
          <button class="btn btn-outline !px-3 !py-2.5 !text-[0.8rem]" data-val-load>{T.loadExample}</button>
        </div>
        <label class="field-label mt-5" for="val-input">{T.pasteJson}</label>
        <textarea class="field-textarea" id="val-input" spellcheck="false" data-val-input placeholder='{"version":"0.1", ...}'></textarea>
        <button class="btn btn-primary mt-4" data-val-run>{T.validate}</button>
      </div>

      <div>
        <p class="field-label">{T.output}</p>
        <div class="rounded-md border border-line bg-surface p-5 min-h-40" data-val-result>
          <p class="text-[0.85rem] text-muted">—</p>
        </div>
      </div>
    </section>

    <!-- ============ LICENSE TOKEN DEMO ============ -->
    <section id="panel-token" role="tabpanel" aria-labelledby="tab-token" class="mt-8 hidden grid-cols-1 gap-8 lg:grid-cols-2" data-panel="token">
      <div class="card p-6 md:p-7">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label class="field-label" for="tok-publisher">{T.publisher}</label>
            <input class="field-input" id="tok-publisher" type="text" value="agiright.org" data-tok-publisher />
          </div>
          <div>
            <label class="field-label" for="tok-agent">{T.tokenAgent}</label>
            <input class="field-input" id="tok-agent" type="text" value="agent://example-agent" data-tok-agent />
          </div>
          <div>
            <label class="field-label" for="tok-license">{T.tokenLicense}</label>
            <select class="field-select" id="tok-license" data-tok-license>
              <option value="research_rag" selected>research_rag — read, summarize, rag</option>
              <option value="metered_rag">metered_rag — rag (paid per request)</option>
              <option value="public_read_summary">public_read_summary — read, summarize, quote</option>
            </select>
          </div>
          <div>
            <label class="field-label" for="tok-scope">{T.tokenScope}</label>
            <input class="field-input" id="tok-scope" type="text" value="/docs/*" data-tok-scope />
          </div>
          <div>
            <label class="field-label" for="tok-ttl">{T.tokenTtl}</label>
            <input class="field-input" id="tok-ttl" type="number" min="1" value="60" data-tok-ttl />
          </div>
          <div>
            <label class="field-label" for="tok-secret">{T.tokenSecret}</label>
            <input class="field-input" id="tok-secret" type="text" value="demo-secret-change-me" data-tok-secret />
          </div>
        </div>
        <button class="btn btn-primary mt-6" data-tok-sign>{T.tokenSign}</button>
        <p class="mt-5 border-t border-line pt-4 text-[0.8rem] leading-relaxed text-muted">{T.tokenNote}</p>
      </div>

      <div>
        <div class="flex items-center justify-between gap-3">
          <p class="field-label !mb-0">{T.output} — license token</p>
          <button class="btn btn-outline !px-3 !py-2 !text-[0.8rem]" data-copy="token">{T.copy}</button>
        </div>
        <figure class="terminal mt-3">
          <pre class="max-h-40 overflow-auto whitespace-pre-wrap break-all p-4"><code data-output="token">—</code></pre>
        </figure>

        <label class="field-label mt-6" for="tok-verify-input">{T.tokenPaste}</label>
        <textarea class="field-textarea !min-h-24" id="tok-verify-input" spellcheck="false" data-tok-verify-input></textarea>
        <div class="mt-3 flex flex-wrap gap-2">
          <button class="btn btn-primary !px-3 !py-2 !text-[0.85rem]" data-tok-verify>{T.tokenVerify}</button>
          <button class="btn btn-outline !px-3 !py-2 !text-[0.85rem]" data-tok-tamper>{T.tokenTamper}</button>
        </div>
        <div class="mt-4 rounded-md border border-line bg-surface p-5 min-h-24" data-tok-result>
          <p class="text-[0.85rem] text-muted">—</p>
        </div>
      </div>
    </section>

    <!-- ============ HTTP 402 BUILDER ============ -->
    <section id="panel-h402" role="tabpanel" aria-labelledby="tab-h402" class="mt-8 hidden grid-cols-1 gap-8 lg:grid-cols-2" data-panel="h402">
      <div class="card p-6 md:p-7">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label class="field-label" for="h402-resource">{T.h402Resource}</label>
            <input class="field-input" id="h402-resource" type="text" value="/premium/example-article" data-h402-resource />
          </div>
          <div>
            <label class="field-label" for="h402-contact">{T.contact}</label>
            <input class="field-input" id="h402-contact" type="email" value="licensing@example.org" data-h402-contact />
          </div>
          <div>
            <label class="field-label" for="h402-price">{T.price}</label>
            <input class="field-input" id="h402-price" type="text" value="0.002" data-h402-price />
          </div>
          <div>
            <label class="field-label" for="h402-unit">{T.h402Unit}</label>
            <select class="field-select" id="h402-unit" data-h402-unit>
              <option value="per_request" selected>per_request</option>
              <option value="per_1k_tokens">per_1k_tokens</option>
              <option value="per_month">per_month</option>
            </select>
          </div>
        </div>
        <p class="mt-5 border-t border-line pt-4 text-[0.8rem] leading-relaxed text-muted">{T.h402Note}</p>
        <div class="mt-5 rounded-md border border-line bg-paper px-4 py-3.5">
          <p class="spec-label !text-spec">{T.h402Live}</p>
          <p class="mt-2 text-[0.8rem] text-muted">{T.h402LiveNote}</p>
          <code class="mt-2 block break-all font-mono text-[0.75rem] text-navy">curl -i "https://agiright.org/api/mock/402?resource=/premium/example-article"</code>
          <button class="btn btn-outline mt-3 !px-3 !py-2 !text-[0.8rem]" data-h402-live>{T.h402Live}</button>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between gap-3">
          <p class="field-label !mb-0">{T.output} — HTTP response</p>
          <button class="btn btn-outline !px-3 !py-2 !text-[0.8rem]" data-copy="h402">{T.copy}</button>
        </div>
        <figure class="terminal mt-3">
          <pre class="max-h-[32rem] overflow-auto p-4"><code data-output="h402"></code></pre>
        </figure>
      </div>
    </section>

    <!-- ============ CRAWLER POLICY TESTER ============ -->
    <section id="panel-tester" role="tabpanel" aria-labelledby="tab-tester" class="mt-8 hidden grid-cols-1 gap-8" data-panel="tester">
      <div class="card p-6 md:p-7">
        <p class="max-w-3xl text-[0.9rem] leading-relaxed text-ink-soft">{T.testerNote}</p>
        <div class="mt-5 flex flex-wrap items-end gap-3">
          <div class="flex-1 min-w-64">
            <label class="field-label" for="tester-origin">{T.testerOrigin}</label>
            <input class="field-input" id="tester-origin" type="url" value="https://agiright.org" data-tester-origin />
          </div>
          <button class="btn btn-primary" data-tester-run>{T.testerRun}</button>
        </div>
        <div class="mt-6 overflow-hidden rounded-md border border-line" data-tester-result>
          <p class="bg-surface px-5 py-4 text-[0.85rem] text-muted">—</p>
        </div>
      </div>
    </section>
  </div>

  <script>
    // ------------------------------------------------------------------
    // tabs
    // ------------------------------------------------------------------
    const root = document.querySelector('[data-playground]')!;
    const tabs = root.querySelectorAll<HTMLButtonElement>('[data-tab]');
    const panels = root.querySelectorAll<HTMLElement>('[data-panel]');
    tabs.forEach((tab) =>
      tab.addEventListener('click', () => {
        tabs.forEach((t) => t.setAttribute('aria-selected', String(t === tab)));
        panels.forEach((p) => {
          const active = p.dataset.panel === tab.dataset.tab;
          p.classList.toggle('hidden', !active);
          p.classList.toggle('grid', active);
        });
      })
    );

    const today = new Date().toISOString().slice(0, 10);
    const render = (key: string, obj: unknown) => {
      const out = root.querySelector(`[data-output="${key}"]`);
      if (out) out.textContent = JSON.stringify(obj, null, 2);
    };

    // ------------------------------------------------------------------
    // AICR generator
    // ------------------------------------------------------------------
    function buildAicr() {
      const publisher = (root.querySelector('[data-aicr-publisher]') as HTMLInputElement).value.trim() || 'example.org';
      const contact = (root.querySelector('[data-aicr-contact]') as HTMLInputElement).value.trim();
      const policy: Record<string, Record<string, unknown>> = {};
      root.querySelectorAll<HTMLElement>('[data-right]').forEach((row) => {
        const key = row.dataset.right!;
        const mode = (row.querySelector('[data-mode]') as HTMLSelectElement).value;
        const rule: Record<string, unknown> = {};
        if (mode === 'allowed') rule.allowed = true;
        else {
          rule.allowed = false;
          if (mode === 'license_required') {
            rule.license_required = true;
            if (contact) rule.permission_contact = contact;
          }
        }
        const attr = row.querySelector<HTMLInputElement>('[data-attr]');
        if (attr?.checked && mode === 'allowed') rule.attribution_required = true;
        const words = row.querySelector<HTMLInputElement>('[data-max-words]');
        if (words && mode === 'allowed' && words.value) rule.max_excerpt_words = Number(words.value);
        const ret = row.querySelector<HTMLInputElement>('[data-retention]');
        if (ret && mode === 'allowed' && ret.value) rule.retention_days = Number(ret.value);
        policy[key] = rule;
      });
      return {
        version: '0.1',
        protocol: 'AICR',
        publisher,
        updated: today,
        schema: 'https://agiright.org/schemas/aicr.schema.json',
        default_policy: policy,
      };
    }

    // ------------------------------------------------------------------
    // AICL generator
    // ------------------------------------------------------------------
    const PRESET_TIERS: Record<string, object> = {
      public_read_summary: {
        id: 'public_read_summary',
        rights: ['read', 'summarize', 'quote'],
        price: { amount: '0', currency: 'USD' },
        conditions: ['attribution_required', 'no_model_training', 'no_commercial_redistribution'],
      },
      research_rag: {
        id: 'research_rag',
        rights: ['read', 'summarize', 'rag'],
        price: { amount: '0', currency: 'USD' },
        conditions: ['attribution_required', 'retention_days_30', 'no_model_training'],
      },
      commercial_or_training_license: {
        id: 'commercial_or_training_license',
        rights: ['training', 'fine_tuning', 'commercial_use'],
        requires_contact: true,
      },
    };

    function buildAicl() {
      const publisher = (root.querySelector('[data-aicl-publisher]') as HTMLInputElement).value.trim() || 'example.org';
      const contact = (root.querySelector('[data-aicl-contact]') as HTMLInputElement).value.trim();
      const licenses: object[] = [];
      root.querySelectorAll<HTMLInputElement>('[data-preset]').forEach((cb) => {
        if (!cb.checked) return;
        const tier = structuredClone(PRESET_TIERS[cb.dataset.preset!]) as Record<string, unknown>;
        if (tier.requires_contact && contact) tier.contact = contact;
        licenses.push(tier);
      });
      const customOn = root.querySelector<HTMLInputElement>('[data-custom-enable]')?.checked;
      if (customOn) {
        const rights: string[] = [];
        root.querySelectorAll<HTMLInputElement>('[data-tier-right]').forEach((cb) => {
          if (cb.checked) rights.push(cb.dataset.tierRight!);
        });
        const tier: Record<string, unknown> = {
          id: (root.querySelector('[data-tier-id]') as HTMLInputElement).value.trim() || 'custom_tier',
          rights,
        };
        const amount = (root.querySelector('[data-tier-price]') as HTMLInputElement).value.trim();
        const currency = (root.querySelector('[data-tier-currency]') as HTMLInputElement).value.trim() || 'USD';
        if (amount) tier.price = { amount, currency };
        const conditions = (root.querySelector('[data-tier-conditions]') as HTMLInputElement).value
          .split(',')
          .map((s) => s.trim())
          .filter(Boolean);
        if (conditions.length) tier.conditions = conditions;
        if (root.querySelector<HTMLInputElement>('[data-tier-contact]')?.checked) {
          tier.requires_contact = true;
          if (contact) tier.contact = contact;
        }
        licenses.push(tier);
      }
      return {
        version: '0.1',
        protocol: 'AICL',
        publisher,
        updated: today,
        schema: 'https://agiright.org/schemas/aicl.schema.json',
        licenses,
      };
    }

    // custom tier show/hide
    root.querySelector('[data-custom-enable]')?.addEventListener('change', (e) => {
      root.querySelector('[data-custom-fields]')?.classList.toggle('hidden', !(e.target as HTMLInputElement).checked);
    });

    // live regeneration
    const refresh = () => {
      render('aicr', buildAicr());
      render('aicl', buildAicl());
    };
    root.querySelectorAll('input, select').forEach((el) => {
      el.addEventListener('input', refresh);
      el.addEventListener('change', refresh);
    });
    refresh();

    // copy / download
    root.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) =>
      btn.addEventListener('click', async () => {
        const text = root.querySelector(`[data-output="${btn.dataset.copy}"]`)?.textContent ?? '';
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = root.getAttribute('data-lang') === 'zh' ? '已複製 ✓' : 'Copied ✓';
        setTimeout(() => (btn.textContent = original), 1500);
      })
    );
    root.querySelectorAll<HTMLButtonElement>('[data-download]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const text = root.querySelector(`[data-output="${btn.dataset.download}"]`)?.textContent ?? '';
        const blob = new Blob([text], { type: 'application/json' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = btn.dataset.filename ?? 'policy.json';
        a.click();
        URL.revokeObjectURL(a.href);
      })
    );

    // ------------------------------------------------------------------
    // validator (ajv, draft 2020-12)
    // ------------------------------------------------------------------
    import Ajv2020 from 'ajv/dist/2020';
    import addFormats from 'ajv-formats';

    const ajv = new Ajv2020({ allErrors: true, strict: false });
    addFormats(ajv);
    const schemaCache = new Map<string, ReturnType<typeof ajv.compile>>();

    async function getValidator(id: string) {
      if (!schemaCache.has(id)) {
        const schema = await fetch(`/schemas/${id}.schema.json`).then((r) => r.json());
        schemaCache.set(id, ajv.compile(schema));
      }
      return schemaCache.get(id)!;
    }

    const valInput = root.querySelector('[data-val-input]') as HTMLTextAreaElement;
    const valResult = root.querySelector('[data-val-result]') as HTMLElement;
    const valSchema = root.querySelector('[data-val-schema]') as HTMLSelectElement;
    const isZh = root.getAttribute('data-lang') === 'zh';

    function detectSchema(data: unknown): string {
      const p = (data as Record<string, unknown>)?.protocol;
      if (typeof p === 'string' && ['AICR', 'AICL', 'AIRS', 'AILP'].includes(p)) return p.toLowerCase();
      const d = data as Record<string, unknown>;
      if (d?.default_policy) return 'aicr';
      if (d?.licenses) return 'aicl';
      if (d?.spectrum) return 'airs';
      if (d?.default) return 'ailp';
      return 'aicr';
    }

    root.querySelector('[data-val-load]')?.addEventListener('click', async () => {
      const pick = valSchema.value === 'auto' ? 'aicr' : valSchema.value;
      const url = pick === 'airs' || pick === 'ailp' ? '/ai/rights-spectrum.json' : `/.well-known/${pick}.json`;
      valInput.value = JSON.stringify(await fetch(url).then((r) => r.json()), null, 2);
    });

    root.querySelector('[data-val-run]')?.addEventListener('click', async () => {
      let data: unknown;
      try {
        data = JSON.parse(valInput.value);
      } catch (e) {
        valResult.innerHTML = `<p class="font-mono text-[0.85rem]" style="color:var(--color-deny)">${isZh ? 'JSON 語法錯誤' : 'JSON syntax error'}: ${(e as Error).message}</p>`;
        return;
      }
      const id = valSchema.value === 'auto' ? detectSchema(data) : valSchema.value;
      try {
        const validate = await getValidator(id);
        const ok = validate(data);
        if (ok) {
          valResult.innerHTML = `<p class="font-mono text-[0.9rem]" style="color:var(--color-ok)">${isZh ? `✓ 有效 — 符合 ${id}.schema.json` : `✓ Valid against ${id}.schema.json`}</p>`;
        } else {
          const rows = (validate.errors ?? [])
            .map(
              (err) =>
                `<li class="flex gap-3 py-2 border-t border-line first:border-t-0"><code class="font-mono text-[0.78rem] text-navy shrink-0">${err.instancePath || '/'}</code><span class="text-[0.82rem] text-ink-soft">${err.message ?? ''}</span></li>`
            )
            .join('');
          valResult.innerHTML = `<p class="font-mono text-[0.9rem]" style="color:var(--color-deny)">${isZh ? `✗ 不符合 ${id}.schema.json` : `✗ Does not match ${id}.schema.json`}</p><ul class="mt-3">${rows}</ul>`;
        }
      } catch (e) {
        valResult.innerHTML = `<p class="font-mono text-[0.85rem]" style="color:var(--color-deny)">schema load error: ${(e as Error).message}</p>`;
      }
    });

    // ------------------------------------------------------------------
    // license token demo (HMAC-SHA256 via WebCrypto — educational only)
    // ------------------------------------------------------------------
    const enc = new TextEncoder();
    const esc = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    const b64url = (bytes: Uint8Array) =>
      btoa(String.fromCharCode(...bytes)).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
    const b64urlStr = (s: string) => b64url(enc.encode(s));
    const fromB64url = (s: string) => {
      const padded = s.replace(/-/g, '+').replace(/_/g, '/') + '='.repeat((4 - (s.length % 4)) % 4);
      return atob(padded);
    };

    async function hmac(secret: string, data: string): Promise<string> {
      const key = await crypto.subtle.importKey('raw', enc.encode(secret), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
      const sig = await crypto.subtle.sign('HMAC', key, enc.encode(data));
      return b64url(new Uint8Array(sig));
    }

    const TOKEN_RIGHTS: Record<string, string[]> = {
      research_rag: ['read', 'summarize', 'rag'],
      metered_rag: ['rag'],
      public_read_summary: ['read', 'summarize', 'quote'],
    };

    const tokVerifyInput = root.querySelector('[data-tok-verify-input]') as HTMLTextAreaElement;
    const tokResult = root.querySelector('[data-tok-result]') as HTMLElement;

    root.querySelector('[data-tok-sign]')?.addEventListener('click', async () => {
      const licenseId = (root.querySelector('[data-tok-license]') as HTMLSelectElement).value;
      const ttlMin = Number((root.querySelector('[data-tok-ttl]') as HTMLInputElement).value) || 60;
      const now = Math.floor(Date.now() / 1000);
      const header = { alg: 'HS256', typ: 'AICL-license+jwt' };
      const payload = {
        iss: (root.querySelector('[data-tok-publisher]') as HTMLInputElement).value.trim() || 'example.org',
        sub: (root.querySelector('[data-tok-agent]') as HTMLInputElement).value.trim() || 'agent://example',
        license_id: licenseId,
        rights: TOKEN_RIGHTS[licenseId] ?? ['read'],
        scope: (root.querySelector('[data-tok-scope]') as HTMLInputElement).value.trim() || '/*',
        iat: now,
        exp: now + ttlMin * 60,
        nonce: crypto.randomUUID(),
      };
      const signingInput = `${b64urlStr(JSON.stringify(header))}.${b64urlStr(JSON.stringify(payload))}`;
      const secret = (root.querySelector('[data-tok-secret]') as HTMLInputElement).value;
      const token = `${signingInput}.${await hmac(secret, signingInput)}`;
      const out = root.querySelector('[data-output="token"]');
      if (out) out.textContent = token;
      tokVerifyInput.value = token;
    });

    root.querySelector('[data-tok-verify]')?.addEventListener('click', async () => {
      const token = tokVerifyInput.value.trim();
      const secret = (root.querySelector('[data-tok-secret]') as HTMLInputElement).value;
      const parts = token.split('.');
      const bad = (msg: string) =>
        (tokResult.innerHTML = `<p class="font-mono text-[0.9rem]" style="color:var(--color-deny)">${msg}</p>`);
      if (parts.length !== 3) return bad(esc('✗ not a header.payload.signature token'));
      const expected = await hmac(secret, `${parts[0]}.${parts[1]}`);
      if (expected !== parts[2]) return bad(esc(root.getAttribute('data-lang') === 'zh' ? '✗ 簽章無效(內容已被竄改或密鑰不符)' : '✗ Invalid signature (tampered or wrong secret)'));
      let payload: Record<string, unknown>;
      try {
        payload = JSON.parse(fromB64url(parts[1]));
      } catch {
        return bad('✗ signature ok but payload is not valid JSON');
      }
      const expired = typeof payload.exp === 'number' && payload.exp * 1000 < Date.now();
      const isZh = root.getAttribute('data-lang') === 'zh';
      const headline = expired
        ? `<p class="font-mono text-[0.9rem]" style="color:var(--color-warn)">${isZh ? '⚠ 簽章有效,但憑證已過期' : '⚠ Signature valid, but the token has expired'}</p>`
        : `<p class="font-mono text-[0.9rem]" style="color:var(--color-ok)">${isZh ? '✓ 簽章有效' : '✓ Signature valid'}</p>`;
      tokResult.innerHTML =
        headline +
        `<pre class="mt-3 overflow-auto font-mono text-[0.75rem] leading-relaxed text-ink-soft">${esc(JSON.stringify(payload, null, 2))}</pre>`;
    });

    root.querySelector('[data-tok-tamper]')?.addEventListener('click', () => {
      const v = tokVerifyInput.value;
      if (!v.includes('.')) return;
      const i = v.indexOf('.') + 3; // flip a char inside the payload segment
      const c = v[i] === 'A' ? 'B' : 'A';
      tokVerifyInput.value = v.slice(0, i) + c + v.slice(i + 1);
    });

    // ------------------------------------------------------------------
    // HTTP 402 response builder + live mock endpoint
    // ------------------------------------------------------------------
    function buildH402() {
      const resource = (root.querySelector('[data-h402-resource]') as HTMLInputElement).value.trim() || '/premium/example';
      const contact = (root.querySelector('[data-h402-contact]') as HTMLInputElement).value.trim();
      const amount = (root.querySelector('[data-h402-price]') as HTMLInputElement).value.trim() || '0.002';
      const unit = (root.querySelector('[data-h402-unit]') as HTMLSelectElement).value;
      const body = {
        error: 'license_required',
        message: 'This resource requires a license for AI use.',
        resource,
        aicl: 'https://your-site.example/.well-known/aicl.json',
        applicable_licenses: [
          {
            id: 'metered_rag',
            rights: ['rag'],
            price: { amount, currency: 'USD', unit },
            conditions: ['attribution_required', 'no_model_training'],
          },
        ],
        quote_endpoint: 'https://your-site.example/api/aicl/quote',
        contact,
      };
      const text =
        'HTTP/1.1 402 Payment Required\n' +
        'Content-Type: application/json\n' +
        'Link: <https://your-site.example/.well-known/aicl.json>; rel="license-catalog"\n\n' +
        JSON.stringify(body, null, 2);
      const out = root.querySelector('[data-output="h402"]');
      if (out) out.textContent = text;
    }
    ['[data-h402-resource]', '[data-h402-contact]', '[data-h402-price]', '[data-h402-unit]'].forEach((sel) => {
      root.querySelector(sel)?.addEventListener('input', buildH402);
      root.querySelector(sel)?.addEventListener('change', buildH402);
    });
    buildH402();

    root.querySelector('[data-h402-live]')?.addEventListener('click', async () => {
      const resource = (root.querySelector('[data-h402-resource]') as HTMLInputElement).value.trim() || '/premium/example';
      const out = root.querySelector('[data-output="h402"]');
      if (!out) return;
      out.textContent = '…';
      try {
        const res = await fetch(`/api/mock/402?resource=${encodeURIComponent(resource)}`);
        out.textContent = `HTTP ${res.status} ${res.statusText}\nLink: ${res.headers.get('Link') ?? ''}\n\n${JSON.stringify(await res.json(), null, 2)}`;
      } catch (e) {
        out.textContent = `request failed: ${(e as Error).message}`;
      }
    });

    // ------------------------------------------------------------------
    // crawler policy tester
    // ------------------------------------------------------------------
    const testerResult = root.querySelector('[data-tester-result]') as HTMLElement;
    const testerBtn = root.querySelector('[data-tester-run]') as HTMLButtonElement;

    function chip(text: string, color: string) {
      return `<span class="badge" style="color:${color};border-color:color-mix(in srgb, ${color} 45%, transparent)">${text}</span>`;
    }

    testerBtn?.addEventListener('click', async () => {
      const isZh = root.getAttribute('data-lang') === 'zh';
      const origin = (root.querySelector('[data-tester-origin]') as HTMLInputElement).value.trim();
      const original = testerBtn.textContent;
      testerBtn.disabled = true;
      testerBtn.textContent = isZh ? '檢測中…' : 'Inspecting…';
      try {
        const res = await fetch(`/api/crawler-check?origin=${encodeURIComponent(origin)}`);
        const data = await res.json();
        if (!res.ok) {
          testerResult.innerHTML = `<p class="bg-surface px-5 py-4 font-mono text-[0.85rem]" style="color:var(--color-deny)">${esc(data.error ?? 'error')}: ${esc(data.message ?? '')}</p>`;
          return;
        }
        const rows = await Promise.all(
          (data.results as Array<{ path: string; status?: number; body?: string | null; error?: string }>).map(async (r) => {
            let statusChip: string;
            let detail = '';
            if (r.error) {
              statusChip = chip('error', 'var(--color-deny)');
              detail = esc(r.error.slice(0, 80));
            } else if (r.status && r.status >= 200 && r.status < 300) {
              statusChip = chip(isZh ? '存在' : 'found', 'var(--color-ok)');
              if (r.path.endsWith('.json') && r.body) {
                try {
                  const parsed = JSON.parse(r.body);
                  if (r.path.includes('manifest')) {
                    detail = esc(`site: ${parsed.site ?? parsed.url ?? '—'}`);
                  } else {
                    const id = detectSchema(parsed);
                    try {
                      const validate = await getValidator(id);
                      statusChip += ' ' + (validate(parsed)
                        ? chip(isZh ? `符合 ${id} schema` : `${id} schema-valid`, 'var(--color-ok)')
                        : chip(isZh ? `不符合 ${id} schema` : `${id} schema-invalid`, 'var(--color-warn)'));
                    } catch { /* schema fetch failed — skip validation chip */ }
                    if (parsed.default_policy?.training) detail = esc(`training: ${parsed.default_policy.training.allowed ? 'allowed' : 'not allowed'}`);
                    else if (Array.isArray(parsed.licenses)) detail = esc(`${parsed.licenses.length} license tier(s)`);
                    else if (Array.isArray(parsed.spectrum)) detail = esc(`${parsed.spectrum.length} spectrum level(s)`);
                  }
                } catch {
                  statusChip += ' ' + chip(isZh ? 'JSON 解析失敗' : 'invalid JSON', 'var(--color-deny)');
                }
              } else if (r.body) {
                detail = esc(`${r.body.length} bytes`);
              }
            } else {
              statusChip = chip(isZh ? '不存在' : 'missing', 'var(--color-muted, #676c84)');
              detail = r.status ? `HTTP ${r.status}` : '';
            }
            return `<div class="flex flex-wrap items-center gap-3 border-t border-line bg-surface px-5 py-3 first:border-t-0">
              <code class="font-mono text-[0.8rem] font-medium text-navy min-w-56">${esc(r.path)}</code>
              ${statusChip}
              <span class="text-[0.78rem] text-muted">${detail}</span>
            </div>`;
          })
        );
        testerResult.innerHTML =
          `<div class="bg-paper-deep px-5 py-2.5"><span class="spec-label">${esc(data.origin)} · ${esc(data.checked_at ?? '')}</span></div>` +
          rows.join('');
      } catch (e) {
        testerResult.innerHTML = `<p class="bg-surface px-5 py-4 font-mono text-[0.85rem]" style="color:var(--color-deny)">request failed: ${esc((e as Error).message)}</p>`;
      } finally {
        testerBtn.disabled = false;
        testerBtn.textContent = original;
      }
    });
  </script>
</BaseLayout>
