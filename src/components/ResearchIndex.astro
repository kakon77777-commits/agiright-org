---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from './PageHeader.astro';
import { UI, langPrefix, type Lang, pick } from '../data/site';
import { RESEARCH_AREAS } from '../data/research';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const prefix = langPrefix(lang);

const title = pick({ en: 'Research', zh: '研究' }, lang);
const intro =
  pick({ en: 'Six interconnected research areas, from AI rights and content licensing to machine-readable governance and democratic AI network economics.', zh: '六個相互關聯的研究領域,從 AI 權利與內容授權,到機器可讀治理與 AI 網路民主化經濟。' }, lang);
---

<BaseLayout lang={lang} title={title} description={intro}>
  <PageHeader kicker={pick({ en: 'Research areas', zh: '研究領域' }, lang)} title={title} intro={intro} />
  <div class="container-site py-14 md:py-20">
    <div class="space-y-4">
      {
        RESEARCH_AREAS.map((r) => (
          <a
            href={`${prefix}/research/${r.slug}`}
            class="card group grid grid-cols-1 gap-4 p-6 no-underline cursor-pointer md:grid-cols-12 md:items-start md:p-8"
            data-reveal
          >
            <div class="md:col-span-1">
              <span class="font-mono text-lg font-medium text-accent">{r.num}</span>
            </div>
            <div class="md:col-span-4">
              <h2 class="font-serif text-2xl font-semibold text-navy group-hover:text-primary transition-colors duration-200">
                {pick(r.title, lang)}
              </h2>
              {r.protocols.length > 0 && (
                <p class="mt-3 flex flex-wrap gap-1.5">
                  {r.protocols.map((pid) => (
                    <span class="badge">{pid.toUpperCase()}</span>
                  ))}
                </p>
              )}
            </div>
            <p class="text-[0.92rem] leading-relaxed text-muted md:col-span-7">{pick(r.summary, lang)}</p>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
