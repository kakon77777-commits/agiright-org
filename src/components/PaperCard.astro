---
import { langPrefix, UI, type Lang } from '../data/site';
import type { Paper } from '../data/papers';

interface Props {
  paper: Paper;
  lang: Lang;
}
const { paper, lang } = Astro.props;
const t = UI[lang];
const prefix = langPrefix(lang);
---

<a
  href={`${prefix}/docs/whitepapers/${paper.slug}`}
  class="card group block p-6 no-underline cursor-pointer"
  data-reveal
>
  <div class="flex flex-wrap items-center gap-2">
    <span class="badge badge-draft">{paper.version}</span>
    <span class="spec-label">{paper.date}</span>
    {paper.protocols.map((pid) => <span class="badge">{pid.toUpperCase()}</span>)}
  </div>
  <h3 class="font-serif mt-4 text-xl font-semibold leading-snug text-navy group-hover:text-primary transition-colors duration-200 text-balance">
    {paper.title[lang]}
  </h3>
  <p class="mt-3 text-[0.9rem] leading-relaxed text-muted line-clamp-3">{paper.oneLiner[lang]}</p>
  <span class="mt-4 inline-flex items-center gap-1.5 text-[0.85rem] font-medium text-primary">
    {t.readPaper}
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </span>
</a>
