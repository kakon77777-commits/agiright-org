---
import { NAV, UI, SITE, langPrefix, type Lang, pick } from '../data/site';
import { PROTOCOLS } from '../data/protocols';
import Logo from './Logo.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = UI[lang];
const prefix = langPrefix(lang);
const year = new Date().getFullYear();

const machineLinks = [
  { href: '/llms.txt', label: 'llms.txt' },
  { href: '/ai/manifest.json', label: 'ai/manifest.json' },
  { href: '/ai/rights-spectrum.json', label: 'ai/rights-spectrum.json' },
  { href: '/.well-known/aicr.json', label: '.well-known/aicr.json' },
  { href: '/.well-known/aicl.json', label: '.well-known/aicl.json' },
  { href: '/sitemap.xml', label: 'sitemap.xml' },
];
---

<footer class="border-t border-line bg-paper-deep/60 mt-24">
  <div class="container-site py-14">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <a href={prefix || '/'} class="inline-flex items-center gap-2.5">
          <Logo class="h-8 w-8" />
          <span class="font-serif text-xl font-semibold text-navy">AGIRight<span class="text-muted font-normal">.org</span></span>
        </a>
        <p class="mt-4 max-w-sm text-[0.9rem] leading-relaxed text-muted">
          {t.footerTagline}
        </p>
        <p class="mt-4 spec-label">
          {SITE.org} · {SITE.author} · {pick({ en: 'also at', zh: '亦可經' }, lang)} asiright.org
        </p>
      </div>

      <div class="md:col-span-2">
        <p class="spec-label mb-4">{pick({ en: 'Site', zh: '網站' }, lang)}</p>
        <ul class="space-y-2.5 text-[0.9rem]">
          {
            NAV.map((item) => (
              <li>
                <a href={prefix + item.href} class="text-ink-soft hover:text-navy transition-colors duration-200">
                  {pick(item, lang)}
                </a>
              </li>
            ))
          }
          <li>
            <a href={prefix + '/contact'} class="text-ink-soft hover:text-navy transition-colors duration-200">
              {pick({ en: 'Contact', zh: '聯絡' }, lang)}
            </a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <p class="spec-label mb-4">{pick({ en: 'Protocols', zh: '協議' }, lang)}</p>
        <ul class="space-y-2.5 text-[0.9rem]">
          {
            PROTOCOLS.map((p) => (
              <li>
                <a href={`${prefix}/protocols/${p.id}`} class="text-ink-soft hover:text-navy transition-colors duration-200">
                  {p.abbr}
                </a>
              </li>
            ))
          }
          <li>
            <a href={prefix + '/specs'} class="text-ink-soft hover:text-navy transition-colors duration-200">
              {pick({ en: 'All specs', zh: '規範總覽' }, lang)}
            </a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <p class="spec-label mb-4">{pick({ en: 'Machine-readable', zh: '機器可讀' }, lang)}</p>
        <ul class="space-y-2.5">
          {
            machineLinks.map((l) => (
              <li>
                <a href={l.href} class="font-mono text-[0.78rem] text-spec hover:text-navy transition-colors duration-200">
                  /{l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="hairline mt-12 pt-6 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <p class="text-[0.8rem] text-muted">
        © {year} {SITE.org} · {t.footerRights}
      </p>
      <div class="flex items-center gap-5 text-[0.8rem]">
        <a
          href="https://github.com/kakon77777-commits/agiright-org"
          class="inline-flex items-center gap-1.5 text-muted hover:text-navy transition-colors duration-200"
          rel="noopener"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.76 2.69 1.25 3.35.96.1-.75.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.26 5.66.41.35.77 1.05.77 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.66.8.55A10.52 10.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
          GitHub
        </a>
        <a href={prefix + '/docs/changelog'} class="text-muted hover:text-navy transition-colors duration-200">Changelog</a>
        <a href={prefix + '/legal/disclaimer'} class="text-muted hover:text-navy transition-colors duration-200">Disclaimer</a>
        <a href={prefix + '/legal/license'} class="text-muted hover:text-navy transition-colors duration-200">License</a>
        <a href={prefix + '/legal/privacy'} class="text-muted hover:text-navy transition-colors duration-200">Privacy</a>
      </div>
    </div>
  </div>
</footer>
