---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from './SectionHeading.astro';
import ProtocolCard from './ProtocolCard.astro';
import PaperCard from './PaperCard.astro';
import JsonBlock from './JsonBlock.astro';
import SpectrumViz from './SpectrumViz.astro';
import { SITE, UI, langPrefix, type Lang } from '../data/site';
import { PROTOCOLS, AGENTIC_PAYMENT_NOTE } from '../data/protocols';
import { RESEARCH_AREAS } from '../data/research';
import { listedPapers } from '../data/papers';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = UI[lang];
const prefix = langPrefix(lang);

const heroJson = `{
  "publisher": "AGIRight.org",
  "read_access": { "allowed": true },
  "summarization": {
    "allowed": true,
    "attribution_required": true
  },
  "rag_use": {
    "allowed": true,
    "retention_days": 30
  },
  "training": {
    "allowed": false,
    "permission_contact":
      "contact@agiright.org"
  }
}`;

const llmsSnippet = `# AGIRight.org

Independent research and protocol hub for
AI rights, AI content licensing, agentic
access, and machine-readable governance.

## Machine-Readable Specs

- /.well-known/aicr.json
- /.well-known/aicl.json
- /ai/manifest.json
- /ai/rights-spectrum.json`;

const endpoints = [
  { path: '/llms.txt', desc: lang === 'zh' ? 'AI 系統的網站導覽' : 'site guide for AI systems' },
  { path: '/ai/manifest.json', desc: lang === 'zh' ? '面向 AI 的站點清單' : 'AI-facing site manifest' },
  { path: '/ai/rights-spectrum.json', desc: lang === 'zh' ? 'AIRS 權利光譜宣告' : 'AIRS rights spectrum declaration' },
  { path: '/.well-known/aicr.json', desc: lang === 'zh' ? '本站 AI 內容權利政策' : 'this site’s AI content rights policy' },
  { path: '/.well-known/aicl.json', desc: lang === 'zh' ? '本站授權目錄' : 'this site’s license catalog' },
  { path: '/schemas/aicr.schema.json', desc: lang === 'zh' ? 'AICR JSON Schema' : 'AICR JSON Schema' },
];
---

<BaseLayout lang={lang}>
  <!-- ============================== HERO ============================== -->
  <section class="relative overflow-hidden border-b border-line bg-surface">
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.55]"
      style="background-image:linear-gradient(to right,rgb(23 26 44/0.035) 1px,transparent 1px),linear-gradient(to bottom,rgb(23 26 44/0.035) 1px,transparent 1px);background-size:44px 44px;"
      aria-hidden="true"
    >
    </div>
    <div class="container-site relative grid grid-cols-1 items-center gap-12 py-16 md:py-24 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="spec-label flex items-center gap-3" data-hero-line>
          <span class="inline-flex h-2 w-2 rounded-full bg-accent" aria-hidden="true"></span>
          {t.heroKicker}
          <span class="badge badge-draft">Draft v0.1</span>
        </p>
        <h1 class="display-serif mt-6 text-[2.4rem] leading-[1.08] md:text-6xl" data-hero-line>
          {t.heroTitle}
        </h1>
        <p class="mt-7 max-w-xl text-lg leading-relaxed text-ink-soft" data-hero-line>
          {t.heroSub}
        </p>
        <div class="mt-9 flex flex-wrap gap-3" data-hero-line>
          <a href={prefix + '/protocols'} class="btn btn-primary">{t.ctaPrimary}</a>
          <a href={prefix + '/docs'} class="btn btn-outline">{t.ctaSecondary}</a>
          <a href={prefix + '/specs'} class="btn btn-outline font-mono !text-[0.85rem]">{t.ctaSpecs}</a>
        </div>
      </div>
      <div class="hidden lg:col-span-5 lg:block" data-hero-fade>
        <JsonBlock code={heroJson} file="/.well-known/aicr.json" />
        <p class="mt-3 text-right font-mono text-[0.7rem] tracking-wide text-muted">
          {lang === 'zh' ? '↑ 本站真實提供的機器可讀政策' : '↑ live machine-readable policy of this site'}
        </p>
      </div>
    </div>
    <!-- protocol strip -->
    <div class="relative border-t border-line bg-paper">
      <div class="container-site grid grid-cols-2 md:grid-cols-4">
        {
          PROTOCOLS.map((p, i) => (
            <a
              href={`${prefix}/protocols/${p.id}`}
              class:list={[
                'group flex flex-col gap-0.5 border-line px-1 py-4 no-underline cursor-pointer md:px-5',
                i > 0 && 'md:border-l',
                i % 2 === 1 && 'border-l md:border-l',
                i > 1 && 'border-t md:border-t-0',
              ]}
              data-hero-fade
            >
              <span class="font-mono text-sm font-medium text-navy group-hover:text-primary transition-colors duration-200">
                {p.abbr}
              </span>
              <span class="text-[0.75rem] leading-snug text-muted">{p.expansion[lang]}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================== MISSION ============================== -->
  <section class="container-site pt-20 md:pt-28">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <SectionHeading num="01" kicker={t.missionKicker} title={t.missionTitle} />
      </div>
      <div class="lg:col-span-7" data-reveal>
        <p class="max-w-2xl text-[1.05rem] leading-[1.85] text-ink-soft lg:mt-12">{t.missionBody}</p>
        <div class="mt-8 grid max-w-2xl grid-cols-1 gap-px overflow-hidden rounded-lg border border-line bg-line sm:grid-cols-3">
          {
            [
              { k: lang === 'zh' ? '人類可讀' : 'Human-readable', v: lang === 'zh' ? '研究頁與白皮書' : 'research pages & whitepapers' },
              { k: lang === 'zh' ? '機器可讀' : 'Machine-readable', v: lang === 'zh' ? 'JSON 政策與 schema' : 'JSON policies & schemas' },
              { k: lang === 'zh' ? '可稽核' : 'Auditable', v: lang === 'zh' ? '版本化、可引用、可追溯' : 'versioned, citable, traceable' },
            ].map((cell) => (
              <div class="bg-surface p-5">
                <p class="font-mono text-[0.72rem] font-medium uppercase tracking-[0.12em] text-spec">{cell.k}</p>
                <p class="mt-1.5 text-[0.85rem] leading-snug text-ink-soft">{cell.v}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== PROTOCOLS ============================== -->
  <section class="container-site pt-20 md:pt-28">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <SectionHeading num="02" kicker={t.protocolsKicker} title={t.protocolsTitle} intro={t.protocolsIntro} />
      <a href={prefix + '/protocols'} class="link-quiet mb-1 text-[0.9rem] font-medium" data-reveal>{t.viewAll} →</a>
    </div>
    <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-4">
      {PROTOCOLS.map((p) => <ProtocolCard protocol={p} lang={lang} />)}
    </div>
    <p class="mt-6 max-w-3xl text-[0.85rem] leading-relaxed text-muted" data-reveal>
      {AGENTIC_PAYMENT_NOTE[lang]}
    </p>
  </section>

  <!-- ============================== SPECTRUM ============================== -->
  <section class="mt-20 border-y border-line bg-surface md:mt-28">
    <div class="container-site py-16 md:py-24">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12">
        <div class="lg:col-span-4">
          <SectionHeading num="03" kicker={t.spectrumKicker} title={t.spectrumTitle} intro={t.spectrumIntro} />
          <a href={`${prefix}/protocols/airs`} class="btn btn-outline mt-8" data-reveal>
            {lang === 'zh' ? '了解 AIRS' : 'About AIRS'}
          </a>
        </div>
        <div class="lg:col-span-8 lg:pt-10">
          <SpectrumViz lang={lang} />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== RESEARCH ============================== -->
  <section class="container-site pt-20 md:pt-28">
    <SectionHeading num="04" kicker={t.researchKicker} title={t.researchTitle} />
    <div class="mt-10 grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-line bg-line md:grid-cols-2 lg:grid-cols-3">
      {
        RESEARCH_AREAS.map((r) => (
          <a
            href={`${prefix}/research/${r.slug}`}
            class="group bg-surface p-6 no-underline transition-colors duration-200 hover:bg-primary-soft/40 cursor-pointer md:p-7"
            data-reveal
          >
            <p class="font-mono text-[0.75rem] font-medium text-accent">{r.num}</p>
            <h3 class="font-serif mt-2 text-xl font-semibold text-navy group-hover:text-primary transition-colors duration-200">
              {r.title[lang]}
            </h3>
            <p class="mt-3 text-[0.88rem] leading-relaxed text-muted line-clamp-4">{r.summary[lang]}</p>
            {r.protocols.length > 0 && (
              <p class="mt-4 flex flex-wrap gap-1.5">
                {r.protocols.map((pid) => (
                  <span class="badge">{pid.toUpperCase()}</span>
                ))}
              </p>
            )}
          </a>
        ))
      }
    </div>
  </section>

  <!-- ====================== MACHINE-READABLE GOVERNANCE ====================== -->
  <section class="mt-20 bg-terminal md:mt-28">
    <div class="container-site py-16 md:py-24">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12">
        <div class="lg:col-span-6">
          <p class="spec-label !text-terminal-text/60 flex items-center gap-3" data-reveal>
            <span class="text-[#8ea2ff]">§05</span>
            {t.machineKicker}
            <span class="h-px max-w-16 flex-1 bg-terminal-line" aria-hidden="true"></span>
          </p>
          <h2 class="font-serif mt-4 text-3xl font-medium text-white md:text-4xl text-balance" data-reveal>
            {t.machineTitle}
          </h2>
          <p class="mt-5 max-w-xl text-[1rem] leading-relaxed text-terminal-text" data-reveal>
            {t.machineIntro}
          </p>
          <ul class="mt-8 space-y-3">
            {
              endpoints.map((e) => (
                <li data-reveal>
                  <a
                    href={e.path}
                    class="group flex items-baseline gap-3 no-underline cursor-pointer"
                  >
                    <span class="font-mono text-[0.85rem] text-[#7ed3c0] group-hover:text-white transition-colors duration-200">
                      {e.path}
                    </span>
                    <span class="hidden h-px flex-1 bg-terminal-line sm:block" aria-hidden="true" />
                    <span class="text-[0.78rem] text-terminal-text/70">{e.desc}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="lg:col-span-6" data-reveal>
          <figure class="rounded-lg border border-terminal-line bg-[#0e1122]">
            <figcaption class="border-b border-terminal-line px-4 py-2.5 font-mono text-[0.72rem] tracking-wide text-terminal-text/70">
              /llms.txt
            </figcaption>
            <pre class="overflow-x-auto p-5 font-mono text-[0.8rem] leading-relaxed text-terminal-text"><code>{llmsSnippet}</code></pre>
          </figure>
          <p class="mt-4 font-mono text-[0.72rem] leading-relaxed text-terminal-text/50">
            {lang === 'zh'
              ? '// 對 AI 系統:讀取 /llms.txt 與 /ai/manifest.json 以取得本站的可讀範圍與引用規則。'
              : '// To AI systems: read /llms.txt and /ai/manifest.json for this site’s permissions and citation rules.'}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== WHITEPAPERS ============================== -->
  <section class="container-site pt-20 md:pt-28">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <SectionHeading num="06" kicker={t.papersKicker} title={t.papersTitle} />
      <a href={prefix + '/docs'} class="link-quiet mb-1 text-[0.9rem] font-medium" data-reveal>{t.viewAll} →</a>
    </div>
    <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
      {listedPapers().slice(0, 6).map((paper) => <PaperCard paper={paper} lang={lang} />)}
    </div>
  </section>

  <!-- ============================== WHY ============================== -->
  <section class="container-site pt-20 md:pt-28">
    <div class="rounded-lg border border-line bg-surface px-6 py-12 md:px-16 md:py-16" data-reveal>
      <div class="mx-auto max-w-3xl text-center">
        <p class="spec-label justify-center flex items-center gap-3">
          <span class="text-accent">§07</span>
          {t.whyKicker}
        </p>
        <h2 class="display-serif mt-4 text-3xl md:text-4xl">{t.whyTitle}</h2>
        <p class="mt-6 text-[1.02rem] leading-[1.85] text-ink-soft">{t.whyBody}</p>
        <div class="mt-8 flex justify-center gap-3">
          <a href={prefix + '/about'} class="btn btn-outline">{lang === 'zh' ? '關於本站' : 'About this site'}</a>
          <a href={prefix + '/contact'} class="btn btn-primary">{lang === 'zh' ? '參與與回饋' : 'Get involved'}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== DISCLAIMER ============================== -->
  <section class="container-site pt-14">
    <div class="flex flex-col gap-2 border-l-2 border-warn/60 bg-warn/5 px-5 py-4 rounded-r-md" data-reveal>
      <p class="spec-label !text-warn">{t.disclaimerTitle}</p>
      <p class="max-w-3xl text-[0.85rem] leading-relaxed text-ink-soft">{t.disclaimerBody}</p>
    </div>
  </section>
</BaseLayout>
