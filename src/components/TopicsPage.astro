---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from './PageHeader.astro';
import { pick, type Lang } from '../data/site';
import { TOPICS } from '../data/topics';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const title = pick({ en: 'Topics', zh: '議題專區' }, lang);
const intro = pick(
  {
    en: 'A neutral index of third-party writing on AI ontology, philosophy, and frontier progress — not this site’s own position. Summaries are our paraphrase with attribution; read the source for the actual argument.',
    zh: '收錄第三方對 AI 本體論、哲學與前沿進展的論述——並非本站自身的立場。摘要為我們的改寫並附出處,實際論點請見原文。',
  },
  lang
);

const sorted = [...TOPICS].sort((a, b) => (a.date > b.date ? -1 : 1));
const searchPlaceholder = pick({ en: 'Search topics — try a theme, source, or keyword…', zh: '搜尋議題——試試主題、來源或關鍵字…' }, lang);
const noResults = pick({ en: 'No topics match your search.', zh: '沒有符合搜尋條件的議題。' }, lang);
const perPageLabel = pick({ en: 'Per page', zh: '每頁筆數' }, lang);
const prevLabel = pick({ en: 'Previous', zh: '上一頁' }, lang);
const nextLabel = pick({ en: 'Next', zh: '下一頁' }, lang);
const paginationLabel = pick({ en: 'Topics pagination', zh: '議題分頁導覽' }, lang);

const leavingTitle = pick({ en: 'You are leaving AGIRight.org', zh: '您即將離開 AGIRight.org' }, lang);
const leavingBody = pick(
  {
    en: 'This link goes to a site we do not control and did not write. Make sure you recognize the destination before continuing.',
    zh: '這個連結會前往我們不掌控、也非本站撰寫的網站。請在繼續前確認您認得這個目的地。',
  },
  lang
);
const leavingContinue = pick({ en: 'Continue to site', zh: '繼續前往' }, lang);
const leavingCancel = pick({ en: 'Cancel', zh: '取消' }, lang);
---

<BaseLayout lang={lang} title={title} description={intro}>
  <PageHeader
    kicker={pick({ en: 'Neutral aggregation — not our position', zh: '中立聚合 — 非本站立場' }, lang)}
    title={title}
    intro={intro}
    badges={[pick({ en: 'Hand-curated — no crawler yet', zh: '人工整理 — 尚未接自動化抓取' }, lang)]}
  />

  <div class="container-site py-14 md:py-20">
    <div class="flex flex-wrap items-center justify-between gap-4" data-reveal>
      <input
        type="text"
        class="field-input w-full max-w-md"
        placeholder={searchPlaceholder}
        autocomplete="off"
        spellcheck="false"
        aria-label={searchPlaceholder}
        data-topics-search
      />
      <label class="flex items-center gap-2 text-[0.8rem] text-muted">
        {perPageLabel}
        <select class="field-select !w-auto" data-topics-pagesize>
          <option value="9">9</option>
          <option value="12">12</option>
          <option value="15">15</option>
        </select>
      </label>
    </div>

    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" data-topics-grid>
      {
        sorted.map((item) => {
          const searchText = `${pick(item.title, lang)} ${pick(item.summary, lang)} ${pick(item.tag, lang)} ${item.sourceName}`.toLowerCase();
          return (
            <article class="card flex flex-col p-6" data-reveal data-topics-item data-search-text={searchText}>
              <div class="flex flex-wrap items-center gap-2">
                <span class="badge">{pick(item.tag, lang)}</span>
                <span class="spec-label">{item.date}</span>
              </div>
              <span class="spec-label !text-muted mt-1.5">{item.sourceName}</span>
              <h2 class="font-serif mt-3 text-lg font-semibold leading-snug text-navy">{pick(item.title, lang)}</h2>
              <p class="mt-2 flex-1 text-[0.85rem] leading-relaxed text-muted">{pick(item.summary, lang)}</p>
              <div class="mt-3 flex flex-col items-start gap-1">
                <a
                  href={item.sourceUrl}
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                  class="link-quiet text-[0.85rem] font-medium"
                  data-external-link
                  data-url={item.sourceUrl}
                >
                  {pick({ en: 'Read the source', zh: '閱讀原文' }, lang)} →
                </a>
                <span class="break-all font-mono text-[0.7rem] text-muted">{item.sourceUrl}</span>
              </div>
            </article>
          );
        })
      }
    </div>

    <p class="hidden py-16 text-center text-[0.9rem] text-muted" data-topics-empty>{noResults}</p>

    <nav
      class="mt-8 hidden flex-wrap items-center justify-center gap-2"
      data-topics-pagination
      aria-label={paginationLabel}
    >
      <button
        type="button"
        class="spec-label !text-ink-soft cursor-pointer rounded-md border border-line-strong px-3 py-1.5 transition-colors duration-200 hover:border-navy disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:border-line-strong"
        data-topics-prev
      >
        ← {prevLabel}
      </button>
      <div class="flex items-center gap-1.5" data-topics-page-numbers></div>
      <button
        type="button"
        class="spec-label !text-ink-soft cursor-pointer rounded-md border border-line-strong px-3 py-1.5 transition-colors duration-200 hover:border-navy disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:border-line-strong"
        data-topics-next
      >
        {nextLabel} →
      </button>
    </nav>
    <p class="mt-2 text-center text-[0.75rem] text-muted" data-topics-page-info aria-live="polite"></p>

    <p class="mx-auto mt-12 max-w-3xl rounded-md border-l-2 border-line-strong bg-surface px-5 py-4 text-[0.85rem] leading-relaxed text-muted" data-reveal>
      {pick(
        {
          en: 'This page links to work we did not write. We do not endorse or vouch for any linked argument — inclusion here means we thought it relevant to AI ontology, philosophy, ethics, or frontier progress, not that we agree with it. Read the linked source before citing it.',
          zh: '本頁連結的內容並非本站撰寫。收錄於此不代表本站認同或背書該論點,只代表我們認為它與 AI 本體論、哲學、倫理或前沿進展相關。引用前請務必查閱原文。',
        },
        lang
      )}
    </p>
  </div>

  <div
    class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/40 p-4 backdrop-blur-sm"
    data-leaving-overlay
  >
    <div
      class="w-full max-w-md rounded-lg border border-line-strong bg-surface p-6 shadow-lg"
      role="dialog"
      aria-modal="true"
      aria-labelledby="leaving-title"
    >
      <h2 id="leaving-title" class="font-serif text-lg font-semibold text-navy">{leavingTitle}</h2>
      <p class="mt-2 text-[0.85rem] leading-relaxed text-muted">{leavingBody}</p>
      <p class="mt-3 break-all rounded-md border border-line bg-paper px-3 py-2 font-mono text-[0.8rem] text-ink-soft" data-leaving-url></p>
      <div class="mt-5 flex justify-end gap-3">
        <button
          type="button"
          class="spec-label !text-ink-soft cursor-pointer rounded-md border border-line-strong px-3 py-1.5 transition-colors duration-200 hover:border-navy"
          data-leaving-cancel
        >
          {leavingCancel}
        </button>
        <button
          type="button"
          class="badge badge-live cursor-pointer transition-colors duration-200 hover:border-navy"
          data-leaving-continue
        >
          {leavingContinue} ↗
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const overlay = document.querySelector<HTMLElement>('[data-leaving-overlay]');
  const urlEl = overlay?.querySelector<HTMLElement>('[data-leaving-url]');
  const cancelBtn = overlay?.querySelector<HTMLButtonElement>('[data-leaving-cancel]');
  const continueBtn = overlay?.querySelector<HTMLButtonElement>('[data-leaving-continue]');
  let pendingUrl: string | null = null;
  let lastFocused: HTMLElement | null = null;

  function openLeaving(url: string, trigger: HTMLElement) {
    if (!overlay || !urlEl) return;
    pendingUrl = url;
    urlEl.textContent = url;
    lastFocused = trigger;
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    continueBtn?.focus();
  }

  function closeLeaving() {
    if (!overlay) return;
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    pendingUrl = null;
    lastFocused?.focus();
  }

  document.querySelectorAll<HTMLAnchorElement>('[data-external-link]').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const url = link.dataset.url;
      if (url) openLeaving(url, link);
    });
  });

  cancelBtn?.addEventListener('click', closeLeaving);
  continueBtn?.addEventListener('click', () => {
    if (pendingUrl) window.open(pendingUrl, '_blank', 'noopener,noreferrer');
    closeLeaving();
  });
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeLeaving();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) closeLeaving();
  });

  const searchInput = document.querySelector<HTMLInputElement>('[data-topics-search]');
  const pageSizeSelect = document.querySelector<HTMLSelectElement>('[data-topics-pagesize]');
  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-topics-item]'));
  const grid = document.querySelector<HTMLElement>('[data-topics-grid]');
  const empty = document.querySelector<HTMLElement>('[data-topics-empty]');
  const pagination = document.querySelector<HTMLElement>('[data-topics-pagination]');
  const pageNumbers = document.querySelector<HTMLElement>('[data-topics-page-numbers]');
  const pageInfo = document.querySelector<HTMLElement>('[data-topics-page-info]');
  const prevBtn = document.querySelector<HTMLButtonElement>('[data-topics-prev]');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-topics-next]');

  const PAGE_SIZE_KEY = 'agiright-topics-page-size';
  let currentPage = 1;

  try {
    const stored = localStorage.getItem(PAGE_SIZE_KEY);
    if (stored && pageSizeSelect && ['9', '12', '15'].includes(stored)) {
      pageSizeSelect.value = stored;
    }
  } catch {
    // localStorage unavailable (private browsing etc.) — default page size still works
  }

  function getPageSize(): number {
    return Number(pageSizeSelect?.value ?? 9);
  }

  function renderPageNumbers(totalPages: number) {
    if (!pageNumbers) return;
    pageNumbers.innerHTML = '';
    for (let p = 1; p <= totalPages; p++) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = String(p);
      btn.setAttribute('aria-current', p === currentPage ? 'page' : 'false');
      btn.className =
        p === currentPage
          ? 'spec-label rounded-md border border-primary bg-primary-soft px-2.5 py-1 text-primary cursor-pointer'
          : 'spec-label !text-ink-soft rounded-md border border-line-strong px-2.5 py-1 cursor-pointer transition-colors duration-200 hover:border-navy';
      btn.addEventListener('click', () => {
        currentPage = p;
        render();
        scrollToTop();
      });
      pageNumbers.appendChild(btn);
    }
  }

  function scrollToTop() {
    searchInput?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function render() {
    const q = (searchInput?.value ?? '').trim().toLowerCase();
    const matched = items.filter((item) => !q || (item.dataset.searchText ?? '').includes(q));

    const pageSize = getPageSize();
    const totalPages = Math.max(1, Math.ceil(matched.length / pageSize));
    currentPage = Math.min(Math.max(1, currentPage), totalPages);
    const start = (currentPage - 1) * pageSize;
    const visibleSet = new Set(matched.slice(start, start + pageSize));

    for (const item of items) {
      item.classList.toggle('hidden', !visibleSet.has(item));
    }

    empty?.classList.toggle('hidden', matched.length > 0);
    grid?.classList.toggle('hidden', matched.length === 0);

    const needsPagination = matched.length > pageSize;
    pagination?.classList.toggle('hidden', !needsPagination);
    pagination?.classList.toggle('flex', needsPagination);
    if (pageInfo) {
      pageInfo.textContent = needsPagination
        ? `${currentPage} / ${totalPages}`
        : '';
    }
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
    renderPageNumbers(totalPages);
  }

  searchInput?.addEventListener('input', () => {
    currentPage = 1;
    render();
  });
  pageSizeSelect?.addEventListener('change', () => {
    try {
      localStorage.setItem(PAGE_SIZE_KEY, pageSizeSelect.value);
    } catch {
      // ignore write failures
    }
    currentPage = 1;
    render();
  });
  prevBtn?.addEventListener('click', () => {
    currentPage--;
    render();
    scrollToTop();
  });
  nextBtn?.addEventListener('click', () => {
    currentPage++;
    render();
    scrollToTop();
  });

  render();
</script>
