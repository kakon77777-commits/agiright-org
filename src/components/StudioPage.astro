---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from './PageHeader.astro';
import { langPrefix, type Lang, pick } from '../data/site';
import { MEDIA } from '../data/media';
import { PROTOCOLS } from '../data/protocols';
import { getPaper } from '../data/papers';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const prefix = langPrefix(lang);

const title = pick({ en: 'Studio', zh: '影音' }, lang);
const intro =
  pick({ en: 'Video and audio companions to the protocols and papers — the AI rights layer, watchable and listenable.', zh: '協議與論文的影音導讀——用看的、用聽的理解 AI 權利層。' }, lang);

const videos = MEDIA.filter((m) => m.kind === 'video');
const audios = MEDIA.filter((m) => m.kind === 'audio');

const protocolName = (id: string) => PROTOCOLS.find((p) => p.id === id)?.abbr ?? id.toUpperCase();
---

<BaseLayout lang={lang} title={title} description={intro}>
  <PageHeader
    kicker={pick({ en: 'Companion media', zh: '影音導讀' }, lang)}
    title={title}
    intro={intro}
    badges={[pick({ en: 'AI-assisted production', zh: 'AI 輔助製作' }, lang)]}
  />

  <div class="container-site py-14 md:py-20">
    <!-- videos -->
    <h2 class="spec-label !text-accent" data-reveal>{pick({ en: 'Videos', zh: '影片' }, lang)}</h2>
    <div class="mt-6 grid grid-cols-1 gap-6 lg:grid-cols-2">
      {
        videos.map((m) => (
          <article class="card overflow-hidden" data-reveal>
            <video
              controls
              preload="metadata"
              class="aspect-video w-full bg-terminal"
              src={`/media/${m.key}`}
            >
              <track kind="captions" />
            </video>
            <div class="p-6">
              <div class="flex flex-wrap items-center gap-2">
                <span class="badge">{pick({ en: 'VIDEO', zh: '影片' }, lang)}</span>
                <span class="spec-label">{m.date}</span>
                {m.protocols.map((pid) => (
                  <a href={`${prefix}/protocols/${pid}`} class="badge no-underline hover:border-navy transition-colors duration-200">
                    {protocolName(pid)}
                  </a>
                ))}
              </div>
              <h3 class="font-serif mt-3 text-xl font-semibold text-navy">{pick(m.title, lang)}</h3>
              <p class="mt-2 text-[0.9rem] leading-relaxed text-muted">{pick(m.desc, lang)}</p>
              {m.papers.length > 0 && (
                <p class="mt-3">
                  {m.papers.map((slug) => (
                    <a href={`${prefix}/docs/whitepapers/${slug}`} class="link-quiet text-[0.85rem] font-medium">
                      {pick({ en: 'Read the paper', zh: '閱讀論文' }, lang)} — {pick(getPaper(slug).title, lang)} →
                    </a>
                  ))}
                </p>
              )}
            </div>
          </article>
        ))
      }
    </div>

    <!-- audio -->
    <h2 class="spec-label !text-accent mt-16" data-reveal>{pick({ en: 'Audio', zh: '音頻' }, lang)}</h2>
    <div class="mt-6 space-y-5">
      {
        audios.map((m) => (
          <article class="card p-6" data-reveal>
            <div class="flex flex-wrap items-center gap-2">
              <span class="badge">{pick({ en: 'AUDIO', zh: '音頻' }, lang)}</span>
              <span class="spec-label">{m.date}</span>
              {m.protocols.map((pid) => (
                <a href={`${prefix}/protocols/${pid}`} class="badge no-underline hover:border-navy transition-colors duration-200">
                  {protocolName(pid)}
                </a>
              ))}
            </div>
            <h3 class="font-serif mt-3 text-xl font-semibold text-navy">{pick(m.title, lang)}</h3>
            <p class="mt-2 max-w-3xl text-[0.9rem] leading-relaxed text-muted">{pick(m.desc, lang)}</p>
            <audio controls preload="metadata" class="mt-4 w-full" src={`/media/${m.key}`} />
            {m.papers.length > 0 && (
              <p class="mt-3">
                {m.papers.map((slug) => (
                  <a href={`${prefix}/docs/whitepapers/${slug}`} class="link-quiet text-[0.85rem] font-medium">
                    {pick({ en: 'Read the paper', zh: '閱讀論文' }, lang)} — {pick(getPaper(slug).title, lang)} →
                  </a>
                ))}
              </p>
            )}
          </article>
        ))
      }
    </div>

    <p class="mt-12 max-w-3xl rounded-md border-l-2 border-line-strong bg-surface px-5 py-4 text-[0.85rem] leading-relaxed text-muted" data-reveal>
      {pick({ en: 'Media in this section is produced with AI tools (narration and discussion are AI-generated), based on the research drafts published on this site; the written papers remain the authoritative versions. Files are served from Cloudflare R2.', zh: '本區影音以 AI 工具輔助製作(旁白與討論為 AI 生成),內容依據本站發布的研究草案;正式論述以文字版論文為準。媒體檔案由 Cloudflare R2 提供。' }, lang)}
    </p>
  </div>
</BaseLayout>
