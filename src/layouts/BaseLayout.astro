---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, publicPath, LANG_META, LANGS, INDEXABLE_LANGS, isIndexable, type Lang, pick } from '../data/site';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  /** true only for pages with no per-language build (currently just 404) —
   * hreflang alternates would otherwise point at URLs that don't exist. */
  noHreflang?: boolean;
}

const { lang, title, description, noHreflang = false } = Astro.props;

const pageTitle = title ? `${title} · ${SITE.name}` : pick(SITE.title, lang);
const pageDesc = description ?? pick(SITE.description, lang);
const pathname = publicPath(Astro.url.pathname.replace(/\.html$/, ''));
/** this page's URL in a given language: bare for English, /<lang>/... otherwise */
function langPath(l: Lang): string {
  if (l === 'en') return pathname;
  return pathname === '/' ? `/${l}` : `/${l}${pathname}`;
}
// Self-referential canonical: each language's URL is now a first-class,
// independently indexable page (see hreflang below), not collapsed onto the
// bare English URL the way it was before the 2026-07-21 site audit.
const canonical = new URL(langPath(lang), SITE.url).href;
const htmlLang = LANG_META[lang].html;
const htmlDir = LANG_META[lang].dir;
// "Option A+" (v1.1 multilingual plan): a locale being routable doesn't by
// itself make it hreflang/sitemap-eligible — that's gated by isIndexable()
// (see site.ts). Every current language is 'indexable' today, so this is a
// no-op now; it's the mechanism a future lower-status language would need.
const thisPageIndexable = isIndexable(lang);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description.en,
  inLanguage: INDEXABLE_LANGS.map((l) => LANG_META[l].html),
  publisher: {
    '@type': 'Organization',
    name: SITE.org,
    email: SITE.email,
  },
};
---

<!doctype html>
<html lang={htmlLang} dir={htmlDir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    {!thisPageIndexable && <meta name="robots" content="noindex" />}
    {
      !noHreflang && thisPageIndexable && (
        <>
          {INDEXABLE_LANGS.map((l) => (
            <link rel="alternate" hreflang={LANG_META[l].html} href={new URL(langPath(l), SITE.url).href} />
          ))}
          <link rel="alternate" hreflang="x-default" href={new URL(pathname, SITE.url).href} />
        </>
      )
    }
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/feed.xml" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={LANG_META[lang].ogLocale} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />

    <!-- fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600&family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@500;600&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- mark JS availability before paint so GSAP entrance states apply cleanly -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-navy focus:text-white focus:px-4 focus:py-2 focus:rounded-md"
      >{pick({ en: 'Skip to content', zh: '跳至主要內容' }, lang)}</a
    >
    <Header lang={lang} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      import { initAnimations } from '../scripts/animations';
      initAnimations();
    </script>
  </body>
</html>
