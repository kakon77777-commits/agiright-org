---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, publicPath, LANG_META, LANGS, type Lang, pick } from '../data/site';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;

const pageTitle = title ? `${title} · ${SITE.name}` : pick(SITE.title, lang);
const pageDesc = description ?? pick(SITE.description, lang);
// one public URL per page: the /zh build tree is internal, so canonical
// always points at the bare path (the edge worker serves the variant there)
const pathname = publicPath(Astro.url.pathname.replace(/\.html$/, ''));
const canonical = new URL(pathname, SITE.url).href;
const htmlLang = LANG_META[lang].html;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description.en,
  inLanguage: LANGS.map((l) => LANG_META[l].html),
  publisher: {
    '@type': 'Organization',
    name: SITE.org,
    email: SITE.email,
  },
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/feed.xml" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={LANG_META[lang].ogLocale} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />

    <!-- fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600&family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@500;600&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- mark JS availability before paint so GSAP entrance states apply cleanly -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-navy focus:text-white focus:px-4 focus:py-2 focus:rounded-md"
      >{pick({ en: 'Skip to content', zh: '跳至主要內容' }, lang)}</a
    >
    <Header lang={lang} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      import { initAnimations } from '../scripts/animations';
      initAnimations();
    </script>
  </body>
</html>
