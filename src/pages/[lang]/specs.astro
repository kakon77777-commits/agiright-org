---
import SpecsPage from '../../components/SpecsPage.astro';
import { NON_DEFAULT_LANGS, type Lang } from '../../data/site';

export function getStaticPaths() {
  return NON_DEFAULT_LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
---

<SpecsPage lang={lang} />
